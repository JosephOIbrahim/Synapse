<?xml version="1.0" encoding="UTF-8"?>
<pythonPanelDocument>
  <interface name="synapse_panel" label="Synapse" icon="SYNAPSE_synapse"
             help_url="">
    <script><![CDATA[
"""
Synapse AI Co-Pilot — Houdini Python Panel (Pentagram layout)

PySide6/PySide2 panel providing:
  - Unified header (branding + status + overflow menu)
  - Context bar with breadcrumb + quick actions
  - Chat interface with Claude API streaming + tool execution (dominant)
  - Collapsible activity log (hidden by default)
  - Compact footer (disconnect + version + ws URL)
"""

import hou
import gc
import hashlib
import base64
import json
import time
import os
import sys
import re
import threading
import copy
import http.client
import ssl


# ── Bootstrap SYNAPSE Python path ─────────────────────────

import sys as _sys_mod
import os as _os_mod
_SYNAPSE_ROOT = _os_mod.environ.get(
    "SYNAPSE_ROOT",
    _os_mod.path.join(_os_mod.path.expanduser("~"), "SYNAPSE"),
)
_synapse_python = _os_mod.path.join(_SYNAPSE_ROOT, "python")
if _synapse_python not in _sys_mod.path:
    _sys_mod.path.insert(0, _synapse_python)
# shared/ lives at repo root — needed for bridge, router, conductor_advisor
if _SYNAPSE_ROOT not in _sys_mod.path:
    _sys_mod.path.insert(0, _SYNAPSE_ROOT)


# ── Bootstrap Design System imports ───────────────────────

_SYNAPSE_HOME = os.path.join(os.path.expanduser("~"), ".synapse")
_DESIGN_DIR = os.path.join(_SYNAPSE_HOME, "design")

if _DESIGN_DIR not in sys.path:
    sys.path.insert(0, _DESIGN_DIR)

try:
    from tokens import (
        SIGNAL, VOID, NEAR_BLACK, CARBON, GRAPHITE, SLATE, SILVER,
        BONE, WHITE, FIRE, GROW, WARN, ERROR, STATES,
        FONT_MONO, SIZE_SMALL, SIZE_LABEL, SIZE_UI, SIZE_BODY,
        SIZE_TITLE, SIZE_HERO,
        SPACE_XS, SPACE_SM, SPACE_MD, SPACE_LG,
        PANEL_MIN_WIDTH, PANEL_PREF_WIDTH, PANEL_MIN_HEIGHT,
    )
    from synapse_styles import generate_stylesheet, STATUS_STYLES
    _HAS_DESIGN = True
except ImportError:
    _HAS_DESIGN = False


try:
    from PySide6 import QtWidgets, QtCore, QtGui
except ImportError:
    from PySide2 import QtWidgets, QtCore, QtGui


# ── Constants ─────────────────────────────────────────────

_VERSION = "6.1.0"
_STATUS_DOT = "\u25CF"  # Filled circle
_STATUS_DOT_EMPTY = "\u25CB"  # Empty circle
_ACTIVITY_MAX_LINES = 200

_PORT = int(os.environ.get("SYNAPSE_PORT", "9999"))
_PATH = os.environ.get("SYNAPSE_PATH", "/synapse")
_WS_URL = "ws://localhost:{}{}".format(_PORT, _PATH)
_HEALTH_POLL_MS = 3000  # Check server health every 3 seconds


# ── Server Singleton ─────────────────────────────────────

def _find_running_server():
    """Find an existing SynapseServer instance via gc (handles zombie servers)."""
    for obj in gc.get_objects():
        if type(obj).__name__ == "SynapseServer" and getattr(obj, "_running", False):
            return obj
    return None


def _get_server_module():
    """Import SynapseServer lazily to avoid import-time issues."""
    try:
        from synapse.server.websocket import SynapseServer
        return SynapseServer
    except ImportError:
        return None


# ── Chat Input Key Filter ─────────────────────────────────

class _InputKeyFilter(QtCore.QObject):
    """Enter sends chat, Shift+Enter inserts newline."""

    def __init__(self, text_edit, panel, parent=None):
        super().__init__(parent or text_edit)
        self._text_edit = text_edit
        self._panel = panel

    def eventFilter(self, obj, event):
        if obj is self._text_edit and event.type() == QtCore.QEvent.KeyPress:
            if event.key() in (QtCore.Qt.Key_Return, QtCore.Qt.Key_Enter):
                if event.modifiers() & QtCore.Qt.ShiftModifier:
                    return False  # Let Shift+Enter insert newline
                self._panel._on_send_chat()
                return True
        return super().eventFilter(obj, event)


# ── Status Dot Animation ─────────────────────────────────

class StatusDotAnimator(QtCore.QObject):
    """Pulses the status dot opacity for 'executing' state."""

    color_changed = QtCore.Signal(str)

    def __init__(self, parent=None):
        super().__init__(parent)
        self._timer = QtCore.QTimer(self)
        self._timer.setInterval(600)
        self._timer.timeout.connect(self._tick)
        self._on = True
        self._color = SIGNAL if _HAS_DESIGN else "#00D4FF"
        self._active = False

    def start(self, color):
        self._color = color
        self._active = True
        self._on = True
        self._timer.start()

    def stop(self, color):
        self._timer.stop()
        self._active = False
        self._color = color
        self.color_changed.emit(color)

    def _tick(self):
        self._on = not self._on
        if self._on:
            self.color_changed.emit(self._color)
        else:
            alpha_color = SLATE if _HAS_DESIGN else "#555555"
            self.color_changed.emit(alpha_color)


# ── Fallback ClaudeWorker (text-only, no tools) ──────────

class _FallbackClaudeWorker(QtCore.QThread):
    """Minimal text-only Claude streaming worker.

    Used when synapse.panel.claude_worker cannot be imported.
    Streams text tokens but does NOT support tool use.
    """

    token_received = QtCore.Signal(str)
    stream_done = QtCore.Signal()
    stream_error = QtCore.Signal(str)
    # Stubs -- never emitted, but wired so the panel doesn't crash
    tool_requested = QtCore.Signal(object)
    tool_status = QtCore.Signal(str, str, str)

    _API_HOST = "api.anthropic.com"
    _API_PATH = "/v1/messages"
    _API_VERSION = "2023-06-01"
    _MODEL = "claude-sonnet-4-6"
    _MAX_TOKENS = 4096

    def __init__(self, messages, system_prompt="", parent=None):
        super().__init__(parent)
        self._messages = copy.deepcopy(messages)
        self._system = system_prompt
        self._abort = False

    def abort(self):
        self._abort = True

    def get_messages(self):
        return copy.deepcopy(self._messages)

    def run(self):
        try:
            api_key = os.environ.get("ANTHROPIC_API_KEY", "")
            if not api_key:
                self.stream_error.emit("ANTHROPIC_API_KEY not set in environment")
                return

            body = {
                "model": self._MODEL,
                "max_tokens": self._MAX_TOKENS,
                "stream": True,
                "messages": self._messages,
            }
            if self._system:
                body["system"] = self._system

            payload = json.dumps(body).encode("utf-8")
            ctx = ssl.create_default_context()
            conn = http.client.HTTPSConnection(
                self._API_HOST, timeout=60, context=ctx
            )

            try:
                conn.request(
                    "POST", self._API_PATH, body=payload,
                    headers={
                        "Content-Type": "application/json",
                        "x-api-key": api_key,
                        "anthropic-version": self._API_VERSION,
                    },
                )
                response = conn.getresponse()
                if response.status != 200:
                    error_body = response.read().decode("utf-8", errors="replace")
                    self.stream_error.emit(
                        "API error {}: {}".format(response.status, error_body[:200])
                    )
                    return

                self._parse_stream(response)
                if not self._abort:
                    self.stream_done.emit()
            finally:
                conn.close()

        except Exception as exc:
            self.stream_error.emit(str(exc))

    def _parse_stream(self, response):
        buf = ""
        while True:
            if self._abort:
                return
            chunk = response.read(4096)
            if not chunk:
                break
            buf += chunk.decode("utf-8", errors="replace")
            while "\n" in buf:
                line, buf = buf.split("\n", 1)
                line = line.strip()
                if line.startswith("data:"):
                    data_str = line[5:].strip()
                    if data_str and data_str != "[DONE]":
                        try:
                            data = json.loads(data_str)
                            delta = data.get("delta", {})
                            text = delta.get("text", "")
                            if text:
                                self.token_received.emit(text)
                        except (json.JSONDecodeError, KeyError):
                            pass


# ── SSE Event Poller ─────────────────────────────────────

class _SSEPoller(QtCore.QObject):
    """Polls the MCP SSE endpoint for server-initiated events.

    Uses a QTimer to periodically GET /mcp with Accept: text/event-stream.
    Emits event_received for each SSE event so the panel can display them.
    """

    event_received = QtCore.Signal(str, str)  # (event_type, data_json)

    def __init__(self, parent=None):
        super().__init__(parent)
        self._timer = QtCore.QTimer(self)
        self._timer.timeout.connect(self._poll)
        self._session_id = None
        self._last_event_id = None
        self._port = None
        self._interval_ms = 3000  # 3 seconds default
        self._consecutive_empties = 0

    def start(self, session_id, port):
        """Start polling with the given MCP session ID and port."""
        self._session_id = session_id
        self._port = port
        self._last_event_id = None
        self._consecutive_empties = 0
        self._interval_ms = 3000
        self._timer.start(self._interval_ms)

    def stop(self):
        """Stop polling."""
        self._timer.stop()
        self._session_id = None

    @property
    def active(self):
        return self._timer.isActive()

    def _poll(self):
        """GET /mcp for SSE events."""
        if not self._session_id or not self._port:
            return

        try:
            conn = http.client.HTTPConnection("localhost", self._port, timeout=5)
            headers = {
                "Accept": "text/event-stream",
                "Mcp-Session-Id": self._session_id,
            }
            if self._last_event_id:
                headers["Last-Event-ID"] = self._last_event_id

            conn.request("GET", "/mcp", headers=headers)
            resp = conn.getresponse()
            body = resp.read().decode("utf-8", errors="replace")
            conn.close()

            if resp.status != 200:
                return

            # Parse SSE events from body
            events = self._parse_sse(body)

            if not events:
                # Adaptive backoff: slow down when idle
                self._consecutive_empties += 1
                if self._consecutive_empties > 5:
                    new_interval = min(self._interval_ms + 1000, 10000)
                    if new_interval != self._interval_ms:
                        self._interval_ms = new_interval
                        self._timer.setInterval(self._interval_ms)
            else:
                # Events received -- reset to fast polling
                self._consecutive_empties = 0
                if self._interval_ms != 3000:
                    self._interval_ms = 3000
                    self._timer.setInterval(self._interval_ms)

                for evt in events:
                    self._last_event_id = evt.get("id")
                    self.event_received.emit(
                        evt.get("event", "unknown"),
                        evt.get("data", "{}"),
                    )

        except Exception:
            pass  # Best-effort -- don't crash the panel

    @staticmethod
    def _parse_sse(body):
        """Parse SSE text into list of event dicts."""
        events = []
        current = {}
        for line in body.split("\n"):
            line = line.strip()
            if line.startswith("id: "):
                current["id"] = line[4:]
            elif line.startswith("event: "):
                current["event"] = line[7:]
            elif line.startswith("data: "):
                current["data"] = line[6:]
            elif line == "" and current:
                if "event" in current:
                    events.append(current)
                current = {}
            elif line.startswith(":"):
                pass  # SSE comment (e.g., ": no events")
        # Handle last event if no trailing blank line
        if current and "event" in current:
            events.append(current)
        return events


# ── Main Panel Widget ────────────────────────────────────

class SynapsePanel(QtWidgets.QWidget):
    """Main Synapse panel widget for Houdini's Python Panel system."""

    def __init__(self):
        super().__init__()
        self.setObjectName("synapse_panel")
        self.setMinimumWidth(PANEL_MIN_WIDTH if _HAS_DESIGN else 280)
        self.setMinimumHeight(PANEL_MIN_HEIGHT if _HAS_DESIGN else 400)

        self._status = "disconnected"
        self._server = None
        self._dot_animator = StatusDotAnimator(self)
        self._dot_animator.color_changed.connect(self._on_dot_color)

        # Chat state
        self._messages = []
        self._worker = None
        self._tool_executor = None  # lazy init
        self._streaming_text = ""
        self._pending_image_path = None  # attached image awaiting send
        self._login_data = None     # shot login context
        self._last_hip = ""         # track hip changes for re-login
        self._last_diagnosis = None # last scene doctor report

        # Sprint 5: UI Evolution state
        self._context_bar_widget = None
        self._context_bar_state = None
        self._palette = None  # lazy init on Ctrl+K
        self._results_display = None  # lazy split-view results panel

        # Font scale (persisted across sessions)
        self._font_scale = 1.0
        self._load_font_scale()

        # Message deduplication (hash -> timestamp)
        self._msg_dedup = {}

        self._build_ui()

        if _HAS_DESIGN:
            self.setStyleSheet(generate_stylesheet())

        # Health poll timer -- checks if server is actually listening
        self._health_timer = QtCore.QTimer(self)
        self._health_timer.setInterval(_HEALTH_POLL_MS)
        self._health_timer.timeout.connect(self._poll_server_health)

        # Sprint 5: Ctrl+K command palette shortcut
        try:
            from PySide6.QtGui import QShortcut, QKeySequence
        except ImportError:
            try:
                from PySide2.QtGui import QShortcut, QKeySequence
            except ImportError:
                QShortcut = None
                QKeySequence = None
        if QShortcut is not None:
            _palette_shortcut = QShortcut(QKeySequence("Ctrl+K"), self)
            _palette_shortcut.activated.connect(self._show_palette)
            self._palette_shortcut = _palette_shortcut  # prevent GC

        # Check for an already-running server (e.g. from a previous panel instance)
        existing = _find_running_server()
        if existing:
            self._server = existing
            port = getattr(existing, "_actual_port", _PORT)
            self._set_status("connected", "port {}".format(port))
            self._log_activity("Found running server on port {}".format(port), "success")
            self._health_timer.start()
        else:
            self._set_status("disconnected")
            self._log_activity("Server not running -- click Connect to start", "info")

        # SSE event poller for MCP server-initiated events
        self._sse_poller = _SSEPoller(self)
        self._sse_poller.event_received.connect(self._on_sse_event)
        QtCore.QTimer.singleShot(2000, self._start_sse_polling)

        # Deferred shot login (avoid blocking panel init)
        QtCore.QTimer.singleShot(200, self._deferred_shot_login)

    def _deferred_shot_login(self):
        """Run shot login after panel is visible, show welcome if needed."""
        self._do_shot_login()
        if not self._login_data or not self._login_data.get("logged_in"):
            self._show_welcome()

    def closeEvent(self, event):
        """Clean up timers and workers to prevent orphaned resources."""
        if self._sse_poller and self._sse_poller.active:
            self._sse_poller.stop()
        if self._health_timer:
            self._health_timer.stop()
        if self._dot_animator and hasattr(self._dot_animator, '_timer'):
            self._dot_animator._timer.stop()
        if self._worker and self._worker.isRunning():
            self._worker.abort()
            self._worker.quit()
            self._worker.wait(2000)
        super().closeEvent(event)

    # ── Font Scale ─────────────────────────────────────────

    _FONT_SCALE_PATH = os.path.join(
        os.path.expanduser("~"), ".synapse", "chat_font_zoom"
    )
    _SCALE_STEP = 0.15
    _SCALE_MIN = 0.5
    _SCALE_MAX = 3.0

    def _sz(self, base):
        """Scale a base pixel size by the current font scale factor."""
        return max(1, int(round(base * self._font_scale)))

    def _load_font_scale(self):
        """Load saved font scale from ~/.synapse/chat_font_zoom."""
        try:
            with open(self._FONT_SCALE_PATH, encoding="utf-8") as f:
                val = float(f.read().strip())
                # Old format saved int zoom steps (0, 1, 2...) — treat < 0.4 as default
                self._font_scale = val if val >= 0.4 else 1.0
        except (FileNotFoundError, ValueError):
            self._font_scale = 1.0

    def _save_font_scale(self):
        """Persist current font scale."""
        try:
            os.makedirs(os.path.dirname(self._FONT_SCALE_PATH), exist_ok=True)
            with open(self._FONT_SCALE_PATH, "w", encoding="utf-8") as f:
                f.write("{:.2f}".format(self._font_scale))
        except OSError:
            pass

    def _rescale_existing_content(self, old_scale, new_scale):
        """Regex-replace all font-size values in existing chat HTML."""
        if abs(old_scale - new_scale) < 0.001:
            return
        ratio = new_scale / old_scale
        html = self._chat_display.toHtml()
        def _scale(m):
            px = float(m.group(1))
            return "font-size:{}px".format(max(1, int(round(px * ratio))))
        html = re.sub(r'font-size:\s*(\d+(?:\.\d+)?)px', _scale, html)
        # Preserve scroll position
        sb = self._chat_display.verticalScrollBar()
        pos = sb.value()
        self._chat_display.setHtml(html)
        sb.setValue(pos)

    def _update_chat_stylesheet(self):
        """Re-set the chat display stylesheet with scaled base font."""
        font_size = self._sz(SIZE_LABEL if _HAS_DESIGN else 9)
        bg = VOID if _HAS_DESIGN else "#0A0A0A"
        fg = BONE if _HAS_DESIGN else "#CCCCCC"
        self._chat_display.setStyleSheet(
            "QTextEdit {{ background: {}; color: {}; border: none; "
            "font-size: {}px; font-family: {}; }}".format(
                bg, fg, font_size,
                FONT_MONO if _HAS_DESIGN else "Consolas, monospace",
            )
        )

    def _on_zoom_in(self):
        """Increase chat font size."""
        old = self._font_scale
        self._font_scale = min(self._SCALE_MAX, old + self._SCALE_STEP)
        self._rescale_existing_content(old, self._font_scale)
        self._update_chat_stylesheet()
        self._save_font_scale()

    def _on_zoom_out(self):
        """Decrease chat font size."""
        old = self._font_scale
        self._font_scale = max(self._SCALE_MIN, old - self._SCALE_STEP)
        self._rescale_existing_content(old, self._font_scale)
        self._update_chat_stylesheet()
        self._save_font_scale()

    def _on_zoom_reset(self):
        """Reset chat font size to default."""
        old = self._font_scale
        self._font_scale = 1.0
        self._rescale_existing_content(old, 1.0)
        self._update_chat_stylesheet()
        self._save_font_scale()

    def _build_ui(self):
        """Construct the panel layout (Pentagram redesign)."""
        layout = QtWidgets.QVBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(0)

        # 1. Unified header (title + status + overflow)
        layout.addWidget(self._build_header())

        # 2. Context Bar v2
        try:
            from synapse.panel.context_bar import (
                build_context_bar_widget, update_context, ContextBarState,
            )
            self._context_bar_state = update_context(
                self._login_data, self._last_diagnosis,
            )
            self._context_bar_widget = build_context_bar_widget(
                self._context_bar_state, self,
            )
            layout.addWidget(self._context_bar_widget)
            # Wire quick-action buttons to _route_cmd
            for btn in self._context_bar_widget.findChildren(
                QtWidgets.QPushButton,
            ):
                cmd = btn.property("command")
                if cmd:
                    btn.clicked.connect(
                        lambda checked=False, c=cmd: self._route_cmd(c)
                    )
        except Exception as exc:
            # Deferred log -- _log is built after this in _build_activity_log
            self._context_bar_error = str(exc)

        # 3. Chat area (dominant, stretch=1)
        layout.addWidget(self._build_chat_area(), stretch=1)

        # 4. Activity log (collapsible, hidden by default)
        layout.addWidget(self._build_activity_log())

        # 5. Agent health (collapsible, hidden by default)
        layout.addWidget(self._build_agent_health())

        # Surface any context bar init failure
        if getattr(self, "_context_bar_error", None):
            QtCore.QTimer.singleShot(
                100, lambda: self._log_activity(
                    "Context bar couldn't load: {}".format(self._context_bar_error),
                    "warning",
                )
            )

        # 6. Compact footer
        layout.addWidget(self._build_connection_bar())

    def _build_header(self):
        """Build unified header: SYNAPSE + status dot + label + detail + overflow."""
        header = QtWidgets.QWidget()
        header.setObjectName("panel_header")
        layout = QtWidgets.QHBoxLayout(header)
        margin_h = SPACE_MD if _HAS_DESIGN else 16
        margin_v = SPACE_XS if _HAS_DESIGN else 4
        layout.setContentsMargins(margin_h, margin_v, margin_h, margin_v)
        layout.setSpacing(SPACE_SM if _HAS_DESIGN else 8)

        # Title
        title = QtWidgets.QLabel("SYNAPSE")
        title.setObjectName("title_label")
        layout.addWidget(title)

        # Status dot (inline)
        self._dot_label = QtWidgets.QLabel(_STATUS_DOT)
        self._dot_label.setObjectName("status_dot")
        layout.addWidget(self._dot_label)

        # Status text
        self._status_label = QtWidgets.QLabel("Idle")
        self._status_label.setObjectName("status_label")
        layout.addWidget(self._status_label)

        layout.addStretch()

        # Status detail (port, clients, etc.)
        self._status_detail = QtWidgets.QLabel("")
        self._status_detail.setObjectName("status_detail")
        layout.addWidget(self._status_detail)

        # Font zoom buttons (A- / A+) with separator spacing
        zoom_spacer = QtWidgets.QWidget()
        zoom_spacer.setFixedWidth(SPACE_SM if _HAS_DESIGN else 6)
        layout.addWidget(zoom_spacer)

        zoom_out_btn = QtWidgets.QPushButton("A\u2212")
        zoom_out_btn.setObjectName("zoom_button")
        zoom_out_btn.setFixedSize(30, 28)
        zoom_out_btn.setToolTip("Decrease chat font size (click to shrink)")
        zoom_out_btn.clicked.connect(self._on_zoom_out)
        layout.addWidget(zoom_out_btn)

        zoom_in_btn = QtWidgets.QPushButton("A+")
        zoom_in_btn.setObjectName("zoom_button")
        zoom_in_btn.setFixedSize(30, 28)
        zoom_in_btn.setToolTip("Increase chat font size (click to enlarge)")
        zoom_in_btn.clicked.connect(self._on_zoom_in)
        layout.addWidget(zoom_in_btn)

        zoom_spacer2 = QtWidgets.QWidget()
        zoom_spacer2.setFixedWidth(SPACE_SM if _HAS_DESIGN else 6)
        layout.addWidget(zoom_spacer2)

        # Overflow menu button
        overflow_btn = QtWidgets.QToolButton()
        overflow_btn.setObjectName("overflow_button")
        overflow_btn.setText("\u22EF")  # midline horizontal ellipsis
        overflow_btn.setPopupMode(QtWidgets.QToolButton.InstantPopup)
        overflow_btn.setMenu(self._build_overflow_menu())
        layout.addWidget(overflow_btn)

        return header

    def _build_overflow_menu(self):
        """Build the overflow QMenu containing the 6 tool actions."""
        menu = QtWidgets.QMenu(self)
        menu.setObjectName("overflow_menu")

        tools = [
            ("Project Setup", "Initialize project memory", self._on_project_setup),
            ("RAG Folder", "Set RAG knowledge folder", self._on_rag_folder),
            ("Inspect Selection", "Analyze selected nodes", self._on_inspect_selection),
            ("Inspect Scene", "Analyze full scene", self._on_inspect_scene),
            ("Health Check", "Run scene check", self._on_health_check),
            ("Last Result", "Copy last result", self._on_last_result),
        ]

        for label, tooltip, callback in tools:
            action = menu.addAction(label)
            action.setToolTip(tooltip)
            action.triggered.connect(callback)

        return menu

    def _build_chat_area(self):
        """Build the chat display, input field, and send button with draggable splitter."""
        frame = QtWidgets.QFrame()
        frame.setObjectName("chat_frame")
        layout = QtWidgets.QVBoxLayout(frame)
        margin_h = SPACE_SM if _HAS_DESIGN else 8
        margin_top = SPACE_MD if _HAS_DESIGN else 16
        layout.setContentsMargins(margin_h, margin_top, margin_h, 0)
        layout.setSpacing(0)

        # Vertical splitter: chat display on top, input area on bottom
        splitter = QtWidgets.QSplitter(QtCore.Qt.Vertical)
        splitter.setObjectName("chat_splitter")
        splitter.setChildrenCollapsible(False)
        handle_bg = GRAPHITE if _HAS_DESIGN else "#222222"
        handle_border = CARBON if _HAS_DESIGN else "#333333"
        splitter.setStyleSheet(
            "QSplitter::handle {{"
            "  background: {bg};"
            "  height: 5px;"
            "  border-top: 1px solid {bd};"
            "  border-bottom: 1px solid {bd};"
            "}}"
            .format(bg=handle_bg, bd=handle_border)
        )

        # Top: chat display (read-only HTML area)
        self._chat_display = QtWidgets.QTextEdit()
        self._chat_display.setObjectName("chat_display")
        self._chat_display.setReadOnly(True)
        self._chat_display.setPlaceholderText("Chat with SYNAPSE...")
        self._update_chat_stylesheet()
        splitter.addWidget(self._chat_display)

        # Bottom: input area (preview strip + input row)
        input_widget = QtWidgets.QWidget()
        input_layout = QtWidgets.QVBoxLayout(input_widget)
        input_layout.setContentsMargins(0, SPACE_SM if _HAS_DESIGN else 4, 0, 0)
        input_layout.setSpacing(0)

        # Image preview strip (hidden by default)
        self._image_preview = QtWidgets.QWidget()
        self._image_preview.setVisible(False)
        preview_row = QtWidgets.QHBoxLayout(self._image_preview)
        preview_row.setContentsMargins(0, 0, 0, 4)
        preview_row.setSpacing(SPACE_SM if _HAS_DESIGN else 6)

        self._image_thumb = QtWidgets.QLabel()
        self._image_thumb.setFixedHeight(48)
        self._image_thumb.setScaledContents(False)
        preview_row.addWidget(self._image_thumb)

        self._image_name = QtWidgets.QLabel()
        self._image_name.setStyleSheet(
            "color: {}; font-size: {}px;".format(
                SILVER if _HAS_DESIGN else "#999999",
                SIZE_SMALL if _HAS_DESIGN else 11,
            )
        )
        preview_row.addWidget(self._image_name, stretch=1)

        clear_btn = QtWidgets.QPushButton("\u2715")
        clear_btn.setFixedSize(24, 24)
        clear_btn.setStyleSheet(
            "QPushButton {{ background: transparent; color: {c}; border: none; "
            "font-size: 14px; border-radius: 4px; }}"
            "QPushButton:hover {{ background: {bg}; color: {w}; }}".format(
                c=SLATE if _HAS_DESIGN else "#555555",
                bg=CARBON if _HAS_DESIGN else "#333333",
                w=WHITE if _HAS_DESIGN else "#FFFFFF",
            )
        )
        clear_btn.setToolTip("Remove attached image")
        clear_btn.clicked.connect(self._on_clear_image)
        preview_row.addWidget(clear_btn)

        input_layout.addWidget(self._image_preview)

        # Input row (attach + text area + send button)
        input_row_widget = QtWidgets.QWidget()
        input_row = QtWidgets.QHBoxLayout(input_row_widget)
        input_row.setContentsMargins(0, 0, 0, 0)
        input_row.setSpacing(SPACE_SM if _HAS_DESIGN else 8)

        self._stop_btn = QtWidgets.QPushButton("\u25A0")
        self._stop_btn.setObjectName("stop_button")
        self._stop_btn.setFixedSize(36, 36)
        self._stop_btn.setToolTip("Stop response")
        self._stop_btn.setVisible(False)
        self._stop_btn.clicked.connect(self._on_stop_stream)
        input_row.addWidget(self._stop_btn, 0, QtCore.Qt.AlignBottom)

        self._attach_btn = QtWidgets.QPushButton("\U0001F4CE")
        self._attach_btn.setObjectName("attach_button")
        self._attach_btn.setFixedSize(36, 36)
        self._attach_btn.setToolTip("Attach reference image")
        self._attach_btn.clicked.connect(self._on_attach_image)
        input_row.addWidget(self._attach_btn, 0, QtCore.Qt.AlignBottom)

        self._chat_input = QtWidgets.QPlainTextEdit()
        self._chat_input.setObjectName("chat_input")
        self._chat_input.setPlaceholderText("Type a message or /help for commands...")
        self._chat_input.setTabChangesFocus(True)
        self._chat_input.setMinimumHeight(40)
        self._chat_input.setMaximumHeight(300)
        self._chat_input.installEventFilter(_InputKeyFilter(self._chat_input, self))
        input_row.addWidget(self._chat_input, 1)

        self._send_btn = QtWidgets.QPushButton("Send")
        self._send_btn.setObjectName("send_button")
        self._send_btn.clicked.connect(self._on_send_chat)
        input_row.addWidget(self._send_btn, 0, QtCore.Qt.AlignBottom)

        input_layout.addWidget(input_row_widget)
        splitter.addWidget(input_widget)

        # Chat dominant, input roomy — 2x default height gives the artist
        # enough room to compose multi-line prompts without resizing first.
        # Stretch factor 0 on input keeps it stable when the panel resizes.
        splitter.setStretchFactor(0, 1)   # chat display stretches
        splitter.setStretchFactor(1, 0)   # input stays fixed
        splitter.setSizes([600, 160])

        layout.addWidget(splitter)

        return frame

    def _build_activity_log(self):
        """Build the collapsible activity log (hidden by default)."""
        frame = QtWidgets.QFrame()
        frame.setObjectName("activity_frame")
        layout = QtWidgets.QVBoxLayout(frame)
        layout.setContentsMargins(
            SPACE_SM if _HAS_DESIGN else 8, 0,
            SPACE_SM if _HAS_DESIGN else 8, 0,
        )
        layout.setSpacing(0)

        # Toggle button
        self._activity_toggle = QtWidgets.QPushButton("\u25B6 ACTIVITY")
        self._activity_toggle.setObjectName("activity_toggle")
        self._activity_toggle.clicked.connect(self._on_toggle_activity)
        layout.addWidget(self._activity_toggle)

        # Log (hidden by default)
        self._log = QtWidgets.QTextEdit()
        self._log.setObjectName("activity_log")
        self._log.setReadOnly(True)
        self._log.setPlaceholderText("Synapse activity will appear here...")
        self._log.setVisible(False)
        layout.addWidget(self._log)

        return frame

    def _on_toggle_activity(self):
        """Toggle activity log visibility."""
        visible = not self._log.isVisible()
        self._log.setVisible(visible)
        if visible:
            self._activity_toggle.setText("\u25BC ACTIVITY")
        else:
            self._activity_toggle.setText("\u25B6 ACTIVITY")

    # ── Agent Health Panel ─────────────────────────────────

    def _build_agent_health(self):
        """Build collapsible agent health section (MOE observability loop surface)."""
        frame = QtWidgets.QFrame()
        frame.setObjectName("agent_health_frame")
        layout = QtWidgets.QVBoxLayout(frame)
        layout.setContentsMargins(
            SPACE_SM if _HAS_DESIGN else 8, 0,
            SPACE_SM if _HAS_DESIGN else 8, 0,
        )
        layout.setSpacing(0)

        # Toggle button (matches activity log pattern)
        self._health_toggle = QtWidgets.QPushButton("\u25B6 AGENT HEALTH")
        self._health_toggle.setObjectName("activity_toggle")
        self._health_toggle.clicked.connect(self._on_toggle_health)
        layout.addWidget(self._health_toggle)

        # Health display (hidden by default)
        self._health_display = QtWidgets.QTextEdit()
        self._health_display.setObjectName("activity_log")
        self._health_display.setReadOnly(True)
        self._health_display.setPlaceholderText(
            "Agent health data will appear when the bridge is running..."
        )
        self._health_display.setMaximumHeight(200)
        self._health_display.setVisible(False)
        layout.addWidget(self._health_display)

        return frame

    def _on_toggle_health(self):
        """Toggle agent health panel visibility."""
        visible = not self._health_display.isVisible()
        self._health_display.setVisible(visible)
        if visible:
            self._health_toggle.setText("\u25BC AGENT HEALTH")
            # Immediate refresh on open
            self._update_agent_health()
        else:
            self._health_toggle.setText("\u25B6 AGENT HEALTH")

    def _update_agent_health(self):
        """Refresh agent health display from bridge stats (best-effort)."""
        if not hasattr(self, "_health_display"):
            return
        try:
            from synapse.panel.agent_health import (
                get_agent_health, format_agent_health_html, get_evolution_display,
            )
            health = get_agent_health()
            if health is not None:
                html = format_agent_health_html(health)
                self._health_display.setHtml(html)

                # Update the toggle with a status indicator
                recs = health.get("recommendations", [])
                critical = sum(
                    1 for r in recs
                    if getattr(r, "severity", "") == "critical"
                )
                warns = sum(
                    1 for r in recs
                    if getattr(r, "severity", "") == "warn"
                )
                if critical > 0:
                    indicator = " \u26A0"  # Warning triangle
                elif warns > 0:
                    indicator = " \u25CF"  # Dot
                else:
                    indicator = ""

                arrow = "\u25BC" if self._health_display.isVisible() else "\u25B6"
                stats = health.get("bridge_stats", {})
                total = stats.get("operations_total", 0)
                if total > 0:
                    rate = stats.get("success_rate", 0.0)
                    self._health_toggle.setText(
                        "{} AGENT HEALTH  {:.0%}{}".format(arrow, rate, indicator)
                    )
        except Exception:
            pass

    def _build_connection_bar(self):
        """Build compact footer: disconnect + version + ws URL."""
        frame = QtWidgets.QFrame()
        frame.setObjectName("connection_frame")
        layout = QtWidgets.QHBoxLayout(frame)
        margin_h = SPACE_MD if _HAS_DESIGN else 16
        layout.setContentsMargins(margin_h, 2, margin_h, 2)
        layout.setSpacing(SPACE_SM if _HAS_DESIGN else 8)

        self._connect_btn = QtWidgets.QPushButton("Connect")
        self._connect_btn.setObjectName("connect_button")
        self._connect_btn.clicked.connect(self._on_connect_toggle)
        layout.addWidget(self._connect_btn)

        layout.addStretch()

        version = QtWidgets.QLabel("v" + _VERSION)
        version.setObjectName("version_label")
        layout.addWidget(version)

        self._ws_path_btn = QtWidgets.QPushButton(_WS_URL)
        self._ws_path_btn.setObjectName("ws_path_button")
        self._ws_path_btn.setToolTip("Copy WebSocket URL to clipboard")
        self._ws_path_btn.clicked.connect(self._on_copy_ws_path)
        ws_sz = SIZE_LABEL if _HAS_DESIGN else 11
        ws_color = SLATE if _HAS_DESIGN else "#555555"
        ws_hover = SILVER if _HAS_DESIGN else "#888888"
        ws_font = FONT_MONO if _HAS_DESIGN else "Consolas"
        self._ws_path_btn.setCursor(QtCore.Qt.PointingHandCursor)
        self._ws_path_btn.setStyleSheet(
            "QPushButton {{ background: transparent; color: {c}; border: none; "
            "font-size: {sz}px; font-family: {f}; text-decoration: none; }}"
            "QPushButton:hover {{ color: {h}; text-decoration: underline; }}".format(
                c=ws_color, sz=ws_sz, f=ws_font, h=ws_hover,
            )
        )
        layout.addWidget(self._ws_path_btn)

        return frame

    # ── Message Deduplication ─────────────────────────────

    def _should_show_message(self, msg):
        """Return True if this message hasn't been shown in the last 5 seconds."""
        now = time.time()
        h = hashlib.md5(msg.encode("utf-8", errors="replace")).hexdigest()
        last = self._msg_dedup.get(h, 0)
        if now - last < 5.0:
            return False
        self._msg_dedup[h] = now
        # Prune old entries
        if len(self._msg_dedup) > 100:
            cutoff = now - 10.0
            self._msg_dedup = {
                k: v for k, v in self._msg_dedup.items() if v > cutoff
            }
        return True

    # ── Status Management ────────────────────────────────

    def _set_status(self, state, detail=""):
        """Update the status bar to reflect a new state."""
        self._status = state

        if _HAS_DESIGN and state in STATES:
            state_info = STATES[state]
            color = state_info["color"]
            label = state_info["label"]
        else:
            color = "#00D4FF"
            label = state.capitalize()

        self._status_label.setText(label)
        self._status_detail.setText(detail)

        if state == "executing":
            self._dot_animator.start(color)
        else:
            self._dot_animator.stop(color)
            self._dot_label.setStyleSheet(f"color: {color};")
            self._status_label.setStyleSheet(f"color: {color};")

        # Update connect button text
        if state in ("connected", "idle", "executing"):
            self._connect_btn.setText("Disconnect")
        else:
            self._connect_btn.setText("Connect")

    def _on_dot_color(self, color):
        """Handle animated dot color change."""
        self._dot_label.setStyleSheet(f"color: {color};")

    # ── WS Path Copy ─────────────────────────────────────

    def _on_copy_ws_path(self):
        """Copy the WebSocket URL to clipboard."""
        if self._copy_text(_WS_URL):
            self._log_activity("Copied: {}".format(_WS_URL), "success")
        else:
            self._log_activity("Couldn't copy WS path to clipboard", "error")

    @staticmethod
    def _copy_text(text):
        """Copy text to clipboard via clip.exe (Windows) or Qt fallback."""
        import platform, subprocess
        if platform.system() == "Windows":
            try:
                p = subprocess.run(
                    ["clip"], input=text.encode("utf-8"),
                    creationflags=0x08000000, timeout=5,
                )
                return p.returncode == 0
            except Exception:
                pass
        try:
            app = QtWidgets.QApplication.instance() or QtGui.QGuiApplication.instance()
            if app:
                app.clipboard().setText(text)
                return True
        except Exception:
            pass
        return False

    # ── Activity Log ─────────────────────────────────────

    def _log_activity(self, message, level="info"):
        """Add a timestamped entry to the activity log."""
        timestamp = time.strftime("%H:%M:%S")

        color_map = {
            "info": SILVER if _HAS_DESIGN else "#999999",
            "success": GROW if _HAS_DESIGN else "#00E676",
            "warning": WARN if _HAS_DESIGN else "#FFAB00",
            "error": ERROR if _HAS_DESIGN else "#FF3D71",
            "action": SIGNAL if _HAS_DESIGN else "#00D4FF",
        }
        color = color_map.get(level, color_map["info"])

        html = (
            f'<span style="color: {SLATE if _HAS_DESIGN else "#555555"};">'
            f'{timestamp}</span> '
            f'<span style="color: {color};">{message}</span>'
        )
        self._log.append(html)

        # Trim if too long
        doc = self._log.document()
        if doc.blockCount() > _ACTIVITY_MAX_LINES:
            cursor = self._log.textCursor()
            cursor.movePosition(QtGui.QTextCursor.Start)
            cursor.movePosition(
                QtGui.QTextCursor.Down,
                QtGui.QTextCursor.KeepAnchor,
                doc.blockCount() - _ACTIVITY_MAX_LINES,
            )
            cursor.removeSelectedText()

    # ── SSE Event Handling ─────────────────────────────────

    def _on_sse_event(self, event_type, data_json):
        """Handle an SSE event from the MCP server."""
        try:
            data = json.loads(data_json)
        except (json.JSONDecodeError, TypeError):
            data = {}

        if event_type == "synapse/render_progress":
            status = data.get("status", "unknown")
            tool = data.get("tool", "render")
            self._log_activity(
                "Render {}: {}".format(status, tool), "action"
            )

        elif event_type == "synapse/gate_request":
            op = data.get("operation", "unknown")
            level = data.get("level", "unknown")
            self._log_activity(
                "Gate check ({}) for {}".format(level, op), "warning"
            )

        elif event_type == "synapse/health_update":
            status = data.get("status", "unknown")
            reason = data.get("reason", "")
            msg = "Health: {}".format(status)
            if reason:
                msg += " -- {}".format(reason[:80])
            lvl = "warning" if status == "degraded" else "success"
            self._log_activity(msg, lvl)

        elif event_type == "synapse/memory_evolved":
            self._log_activity("Memory evolved to next stage", "success")

        elif event_type == "synapse/tools_changed":
            self._log_activity("Tool list updated", "info")

    def _start_sse_polling(self):
        """Start SSE polling if hwebserver is available."""
        try:
            port = hou.webServer.port()
        except Exception:
            return

        if not port:
            return

        # Get or create an MCP session for the panel
        try:
            conn = http.client.HTTPConnection("localhost", port, timeout=5)
            body = json.dumps({
                "jsonrpc": "2.0",
                "id": "panel-sse-init",
                "method": "initialize",
                "params": {
                    "clientInfo": {"name": "synapse-panel-sse", "version": "1.0.0"},
                    "protocolVersion": "2025-06-18",
                },
            }, sort_keys=True).encode("utf-8")
            conn.request("POST", "/mcp", body=body, headers={
                "Content-Type": "application/json",
                "Accept": "application/json",
            })
            resp = conn.getresponse()
            session_id = resp.getheader("Mcp-Session-Id")
            resp.read()  # drain
            conn.close()

            if session_id:
                self._sse_poller.start(session_id, port)
                self._log_activity("SSE polling started", "info")
        except Exception:
            pass  # Best-effort

    # ── Tool Callbacks ───────────────────────────────────

    def _on_project_setup(self):
        """Initialize project memory via shelf callback."""
        self._log_activity("Setting up project...", "action")
        self._set_status("executing", "Project setup")
        try:
            import synapse_shelf
            synapse_shelf.project_setup()
            self._log_activity("Project structure ready", "success")
            self._set_status("idle")
        except Exception as e:
            self._log_activity(f"Project setup hit a snag: {e}", "error")
            self._set_status("warning", str(e)[:40])

    def _on_rag_folder(self):
        """Set RAG knowledge folder via shelf callback."""
        self._log_activity("Opening RAG folder picker...", "action")
        try:
            import synapse_shelf
            synapse_shelf.rag_folder()
            import os
            rag = os.environ.get("SYNAPSE_RAG_ROOT", "")
            if rag:
                self._log_activity("RAG folder: {}".format(rag), "success")
            else:
                self._log_activity("RAG folder cleared", "info")
        except Exception as e:
            self._log_activity("RAG folder setup: {}".format(e), "error")

    def _on_inspect_selection(self):
