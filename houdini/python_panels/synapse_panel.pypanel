<?xml version="1.0" encoding="UTF-8"?>
<pythonPanelDocument>
  <!-- This file contains definitions of Python interfaces and the
 interfaces menu.  It should not be hand-edited when it is being
 used by the application.  Note, that two definitions of the
 same interface or of the interfaces menu are not allowed
 in a single file. -->
  <interface name="synapse_panel" label="Synapse" icon="MISC_python" showNetworkNavigationBar="false" help_url="">
    <script><![CDATA[
# Thin loader for the redesigned, modular SYNAPSE panel.
# The panel itself lives in synapse.panel.synapse_panel (testable, design-system
# driven); this .pypanel just bootstraps the path and hands Houdini the widget.
# Replaces the former 3032-line inline monolith (preserved in git history).
import sys
import os

# Make the synapse package importable. The Houdini package already prepends
# <repo>/python to PYTHONPATH; this is belt-and-suspenders for exec() context
# (pypanel scripts run via exec, so __file__ is undefined).
# SYNAPSE_ROOT is set by the synapse Houdini package (packages/synapse.json, which derives
# it portably from $HOUDINI_PACKAGE_PATH). Add BOTH <root>/python (the synapse package) AND
# <root> itself — shared/ (Lossless bridge, advisor) lives at the repo root, not under python/,
# and SynapseHandler -> handlers_render does `from shared...`; omitting the root silently breaks
# the handler surface (the old "processes but no nodes" bug). NO hardcoded user path: if
# SYNAPSE_ROOT is unset we rely on the package's PYTHONPATH; if synapse is still unimportable,
# onCreateInterface() below surfaces a clear in-panel error instead of pointing at a wrong path.
_root = os.environ.get("SYNAPSE_ROOT", "")
if _root:
    for _p in (os.path.join(_root, "python"), _root):
        if os.path.isdir(_p) and _p not in sys.path:
            sys.path.insert(0, _p)

# Hot-reload: flush cached synapse modules so reopening the panel picks up code
# edits without a Houdini restart. The design system is vendored under
# synapse.panel.designsystem, so there is NO ~/.synapse/design dependency.
for _m in sorted(k for k in sys.modules if k.startswith("synapse.")):
    del sys.modules[_m]
sys.modules.pop("synapse", None)


def onCreateInterface():
    """Houdini Python Panel entry point. Houdini calls onCreateInterface()
    (confirmed against SideFX's own shipped example panels)."""
    try:
        from synapse.panel.synapse_panel import onCreateInterface as _build
        return _build()
    except Exception:
        # Never crash Houdini's panel system  surface the error in-panel.
        import traceback
        try:
            from PySide6 import QtWidgets
        except ImportError:
            from PySide2 import QtWidgets
        view = QtWidgets.QPlainTextEdit()
        view.setReadOnly(True)
        view.setPlainText("SYNAPSE panel failed to load:\n\n" + traceback.format_exc())
        return view


# Some Houdini code paths / older docs use createInterface  alias for safety.
createInterface = onCreateInterface
]]></script>
    <includeInToolbarMenu menu_position="0" create_separator="false"/>
    <help><![CDATA[SYNAPSE — talk to Houdini in plain English.

Type what you want ("make a box", "set up a 3-point light rig", "build a
Karma render") and SYNAPSE builds it in your live scene — real nodes, not
suggestions. Pick your AI engine in the panel (Claude, Gemini, NVIDIA
Nemotron, Ollama for local models, or a Custom OpenAI-compatible endpoint)
and a model to match.

Every action is undo-safe and recorded: nothing happens to your scene that
you can't undo, and there's a receipt for what was done and why. Press the
Connect button if the panel says it can't reach Houdini, and use the
"/" command palette to browse the 115 built-in tools.

The panel code lives in synapse.panel; this file just loads it.]]></help>
  </interface>
</pythonPanelDocument>
