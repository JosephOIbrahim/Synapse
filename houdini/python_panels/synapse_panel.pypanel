    # ── Shot Login & HDA ────────────────────────────────────

    def _do_shot_login(self):
        """Load memory context from all layers (shot login)."""
        try:
            from synapse.panel.shot_login import shot_login, format_memory_for_prompt
            hip = ""
            try:
                import hou as _hou
                hip = _hou.hipFile.path()
            except Exception:
                pass
            self._login_data = shot_login(hip)
            self._last_hip = hip
            if self._login_data.get("logged_in"):
                stage_info = "project={}, scene={}".format(
                    self._login_data.get("project_evolution", "?"),
                    self._login_data.get("scene_evolution", "?"),
                )
                self._sys("Shot login: " + stage_info)
                try:
                    from synapse.panel.session_journal import get_journal
                    get_journal().log_event("LOGIN", stage_info)
                except Exception:
                    pass
                # Gather cross-scene project context
                try:
                    from synapse.panel.cross_scene import gather_project_context, format_project_context_for_prompt
                    project_dir = self._login_data.get("project_dir", "")
                    if project_dir:
                        insights = gather_project_context(project_dir, hip)
                        if insights:
                            self._login_data["project_insights"] = format_project_context_for_prompt(insights)
                            self._sys("Project context: {} insights from other scenes".format(len(insights)))
                except ImportError:
                    pass
                except Exception:
                    pass
            else:
                self._sys("Shot login: no memory loaded (outside project)")
        except ImportError:
            self._login_data = None
            self._sys("Shot login unavailable (synapse.panel.shot_login not found)")
        except Exception as e:
            self._login_data = None
            self._sys("Shot login error: " + str(e))

    def _do_diagnose(self, scope=""):
        """Run scene doctor and display results."""
        scope = scope.strip() or "all"
        self._log_activity("Running scene doctor ({})...".format(scope), "action")
        try:
            from synapse.panel.scene_doctor import diagnose_scene, format_report_html
            report = diagnose_scene(scope)
            self._chat_display.append(format_report_html(report))
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())
            self._last_diagnosis = report
            self._log_activity(report.summary, "info")
            # Log to journal
            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/diagnose", report.summary)
            except Exception:
                pass
            # Hint about /fix if fixable issues exist
            fixable = sum(1 for i in report.issues if i.fix_available)
            if fixable:
                self._sys(
                    "{} issue{} can be auto-fixed. Type /fix to apply.".format(
                        fixable, "s" if fixable != 1 else ""
                    )
                )
        except ImportError:
            self._sys("Scene doctor unavailable (synapse.panel.scene_doctor not found)")
        except Exception as e:
            self._sys("Scene doctor error: " + str(e))

    def _do_fix(self):
        """Apply auto-fixes from the last /diagnose run."""
        if self._last_diagnosis is None:
            self._sys("No diagnosis to fix. Run /diagnose first.")
            return
        fixable = [i for i in self._last_diagnosis.issues if i.fix_available and i.fix_fn is not None]
        if not fixable:
            self._sys("No fixable issues in the last diagnosis.")
            self._last_diagnosis = None
            return
        self._log_activity("Applying {} auto-fix(es)...".format(len(fixable)), "action")
        try:
            from synapse.panel.scene_doctor import apply_fixes
            result = apply_fixes(self._last_diagnosis.issues)
            msg = "Fixed {}, failed {}, skipped {}".format(
                result["fixed"], result["failed"], result["skipped"]
            )
            self._sys(msg)
            self._log_activity(msg, "success" if result["failed"] == 0 else "warning")
            # Log to journal
            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/fix", msg)
            except Exception:
                pass
            self._last_diagnosis = None
            # Re-run diagnose to show remaining issues
            self._do_diagnose("")
        except ImportError:
            self._sys("Scene doctor unavailable (synapse.panel.scene_doctor not found)")
        except Exception as e:
            self._sys("Fix error: " + str(e))

    def _do_preflight(self, render_node=""):
        """Run render preflight checks."""
        render_node = render_node.strip()
        label = render_node if render_node else "auto-detect"
        self._log_activity("Running preflight ({})...".format(label), "action")
        try:
            from synapse.panel.render_preflight import run_preflight, format_preflight_html
            report = run_preflight(render_node)
            self._chat_display.append(format_preflight_html(report))
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())
            self._log_activity(report.summary, "success" if report.ready else "warning")
            # Log to journal
            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/preflight", report.summary)
            except Exception:
                pass
        except ImportError:
            self._sys("Preflight unavailable (synapse.panel.render_preflight not found)")
        except Exception as e:
            self._sys("Preflight error: " + str(e))

    def _do_journal(self, query=""):
        """Display session journal entries."""
        query = query.strip()
        try:
            from synapse.panel.session_journal import get_journal, format_journal_html
            journal = get_journal()
            if query:
                entries = journal.search(query)
            else:
                entries = journal.get_entries(50)
            self._chat_display.append(format_journal_html(entries, query))
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())
        except ImportError:
            self._sys("Journal unavailable (synapse.panel.session_journal not found)")
        except Exception as e:
            self._sys("Journal error: " + str(e))

    def _do_hda(self, description):
        """Launch HDA design conversation with Claude."""
        try:
            from synapse.panel.prompt_to_hda import (
                HDA_DESIGN_PROMPT, parse_hda_command, build_hda_messages,
            )
            from synapse.panel.system_prompt import build_system_prompt
        except ImportError as e:
            self._sys("HDA workflow unavailable: " + str(e))
            return

        # Build HDA-specific system prompt
        context = self._gather_context()
        system_prompt = build_system_prompt(context)
        system_prompt += "\n\n" + HDA_DESIGN_PROMPT
        system_prompt = self._build_memory_system_prompt(system_prompt)

        # Build messages
        parsed = parse_hda_command("/hda " + description)
        messages = build_hda_messages(parsed["description"], context)

        self._launch_worker(messages, system_prompt)

    # ── Chat Methods ───────────────────────────────────────

    def _sys(self, msg):
        """Append a system-level message to the chat display (with dedup)."""
        if not self._should_show_message(msg):
            return
        color = SLATE if _HAS_DESIGN else "#555555"
        html = '<div style="color: {}; font-size: {}px; margin: 2px 0;">{}</div>'.format(
            color, SIZE_LABEL if _HAS_DESIGN else 9, msg,
        )
        self._chat_display.append(html)
        sb = self._chat_display.verticalScrollBar()
        sb.setValue(sb.maximum())

    def _gather_context(self):
        """Gather current Houdini scene context for the system prompt."""
        ctx = {
            "network": "/obj",
            "selection": [],
            "frame": 1,
            "hip": "untitled.hip",
        }
        try:
            ctx["network"] = hou.ui.paneTabOfType(
                hou.paneTabType.NetworkEditor
            ).pwd().path()
        except Exception:
            pass
        try:
            ctx["selection"] = [n.path() for n in hou.selectedNodes()]
        except Exception:
            pass
        try:
            ctx["frame"] = int(hou.frame())
        except Exception:
            pass
        try:
            ctx["hip"] = hou.hipFile.name()
        except Exception:
            pass
        return ctx

    def _ensure_tool_executor(self):
        """Lazily create the main-thread ToolExecutor."""
        if self._tool_executor is None:
            try:
                from synapse.panel.tool_executor import ToolExecutor
                self._tool_executor = ToolExecutor(parent=self)
            except ImportError as e:
                self._sys("Tool executor not available: " + str(e))
        return self._tool_executor

    def _on_stop_stream(self):
        """Stop the active Claude response stream."""
        if self._worker and self._worker.isRunning():
            self._worker.abort()
            self._log_activity("Response stopped", "info")
        self._send_btn.setEnabled(True)
        self._stop_btn.setVisible(False)
        self._attach_btn.setVisible(True)

    def _on_attach_image(self):
        """Open file picker to attach a reference image."""
        path, _ = QtWidgets.QFileDialog.getOpenFileName(
            self, "Attach Reference Image", "",
            "Images (*.png *.jpg *.jpeg *.bmp *.tga *.tif *.tiff *.exr)"
        )
        if not path:
            return
        self._pending_image_path = path

        # Show preview strip
        pixmap = QtGui.QPixmap(path)
        if not pixmap.isNull():
            scaled = pixmap.scaledToHeight(
                48, QtCore.Qt.SmoothTransformation
            )
            self._image_thumb.setPixmap(scaled)
        else:
            self._image_thumb.setText("[img]")
        self._image_name.setText(os.path.basename(path))
        self._image_preview.setVisible(True)

    def _on_clear_image(self):
        """Remove the pending attached image."""
        self._pending_image_path = None
        self._image_preview.setVisible(False)
        self._image_thumb.clear()
        self._image_name.clear()

    def _on_send_chat(self):
        """Handle send button click or Enter key in chat input."""
        text = self._chat_input.toPlainText().strip()
        if not text and not self._pending_image_path:
            return
        self._chat_input.clear()

        # Route slash commands (no image attachment for commands)
        if text.startswith("/"):
            self._route_cmd(text)
            return

        self._chat(text)

    def _route_cmd(self, text):
        """Route slash commands to their handlers."""
        parts = text.split(None, 1)
        cmd = parts[0].lower()
        arg = parts[1].strip() if len(parts) > 1 else ""

        if cmd == "/hda":
            if not arg:
                self._sys("Usage: /hda &lt;describe what you want to build&gt;")
                return
            # Display user message
            label_color = SILVER if _HAS_DESIGN else "#999999"
            label_sz = SIZE_LABEL if _HAS_DESIGN else 9
            user_html = (
                '<div style="margin: 8px 0 4px 0;">'
                '<span style="color: {}; font-size: {}px; letter-spacing: 1px;">'
                'YOU</span></div>'
                '<div style="margin: 0 0 8px 10px;">{}</div>'
            ).format(label_color, label_sz, arg.replace("\n", "<br>"))
            self._chat_display.append(user_html)
            self._do_hda(arg)
        elif cmd == "/diagnose":
            self._do_diagnose(arg)
        elif cmd == "/fix":
            self._do_fix()
        elif cmd == "/preflight":
            self._do_preflight(arg)
        elif cmd == "/journal":
            self._do_journal(arg)
        elif cmd == "/login":
            self._do_shot_login()
        elif cmd == "/explain":
            self._do_explain(arg)
        elif cmd == "/trace":
            self._do_trace(arg)
        elif cmd == "/vex":
            self._do_vex(arg)
        elif cmd == "/recipes" or cmd == "/recipe":
            self._do_recipes(arg)
        elif cmd == "/apex":
            self._do_apex(arg)
        elif cmd == "/help":
            self._show_help()
        elif cmd == "/deps":
            self._do_deps(arg)
        elif cmd == "/profile":
            self._do_profile(arg)
        elif cmd in ("/save-shot", "/save"):
            self._do_save_shot(arg)
        elif cmd == "/shots":
            self._do_shots(arg)
        elif cmd in ("/bookmark", "/bookmarks"):
            self._do_bookmark(arg)
        elif cmd == "/palette":
            self._show_palette()
        else:
            self._sys("Unknown command: {}. Type /help for available commands.".format(cmd))

    def _show_help(self):
        """Display available slash commands in the chat."""
        help_lines = [
            "<b>Available commands:</b>",
            "",
            "  <b>Build</b>",
            "  /hda &lt;description&gt; -- Design and build an HDA from a description",
            "  /recipes [category] [recipe] -- Browse and build network recipes",
            "",
            "  <b>Learn</b>",
            "  /explain [node_path] -- Explain selected node or network data flow",
            "  /vex explain -- Explain VEX code in selected wrangle",
            "  /vex help &lt;function&gt; -- VEX function reference and tutorial",
            "  /vex write &lt;description&gt; -- Generate VEX code from description",
            "  /trace [network_path] -- Trace data flow through a network",
            "",
            "  <b>Rigging</b>",
            "  /apex -- APEX rigging tools (explain, trace, recipes, migrate)",
            "",
            "  <b>Check</b>",
            "  /diagnose [scope] -- Run scene doctor (scope: all, render, materials, current_network)",
            "  /fix -- Apply auto-fixes from last /diagnose",
            "  /preflight [node] -- Render preflight check (auto-detects render node)",
            "",
            "  <b>Production</b>",
            "  /deps [scope] -- Scan scene dependencies (scope: all, textures, geo, hda, usd)",
            "  /profile [network] -- Profile network cook times and find bottlenecks",
            "  /save-shot [note] -- Save session snapshot (conversation + scene state)",
            "  /shots [search query] -- List or search saved session snapshots",
            "",
            "  <b>Session</b>",
            "  /journal [query] -- View session journal (optional search query)",
            "  /bookmark [label] -- Save and find conversation bookmarks",
            "  /login -- Re-run shot login (reload memory context)",
            "  /help -- Show this help message",
            "",
            "  <b>Shortcuts</b>",
            "  Ctrl+K -- Open command palette (fuzzy search all commands)",
        ]
        color = SILVER if _HAS_DESIGN else "#999999"
        sz = SIZE_SMALL if _HAS_DESIGN else 11
        html = '<div style="color: {}; font-size: {}px; margin: 4px 0;">{}</div>'.format(
            color, sz, "<br>".join(help_lines),
        )
        self._chat_display.append(html)
        sb = self._chat_display.verticalScrollBar()
        sb.setValue(sb.maximum())

    def _html_assistant_start(self):
        """Return the HTML header for an assistant (SYNAPSE) message block."""
        label_color = SILVER if _HAS_DESIGN else "#999999"
        sz = SIZE_LABEL if _HAS_DESIGN else 9
        return (
            '<div style="margin: 10px 0 2px 0;">'
            '<span style="color: {}; font-size: {}px; letter-spacing: 1px;">'
            'SYNAPSE</span></div>'
            '<div id="stream_target" style="margin: 0 0 8px 0;">'.format(
                label_color, sz,
            )
        )

    def _launch_worker(self, messages, system_prompt, tools=None):
        """Launch a ClaudeWorker with standard signal wiring."""
        self._send_btn.setEnabled(False)
        self._stop_btn.setVisible(True)
        self._attach_btn.setVisible(False)
        self._streaming_text = ""
        self._chat_display.append(self._html_assistant_start())

        try:
            from synapse.panel.claude_worker import ClaudeWorker as NewWorker
            WorkerClass = NewWorker
            _has_tools = True
        except ImportError:
            WorkerClass = _FallbackClaudeWorker
            _has_tools = False

        worker_kwargs = dict(
            messages=messages,
            system_prompt=system_prompt,
            parent=self,
        )
        if tools is not None and _has_tools:
            worker_kwargs["tools"] = tools

        self._worker = WorkerClass(**worker_kwargs)
        self._worker.token_received.connect(self._on_token)
        self._worker.stream_done.connect(self._on_done)
        self._worker.stream_error.connect(self._on_error)

        if _has_tools:
            executor = self._ensure_tool_executor()
            if executor is not None:
                self._worker.tool_requested.connect(executor.execute_tool)
            self._worker.tool_status.connect(self._on_tool_status)

        self._worker.start()

    def _build_memory_system_prompt(self, base_prompt):
        """Append memory context from shot login to a base system prompt."""
        system_prompt = base_prompt
        if self._login_data and self._login_data.get("logged_in"):
            try:
                from synapse.panel.shot_login import format_memory_for_prompt
                memory_ctx = format_memory_for_prompt(self._login_data)
                if memory_ctx:
                    system_prompt += "\n\n" + memory_ctx
            except ImportError:
                pass
        # Append cross-scene project insights if available
        if self._login_data and self._login_data.get("project_insights"):
            system_prompt += "\n\n" + self._login_data["project_insights"]
        return system_prompt

    # ── Production Pipeline ────────────────────────────────

    def _do_deps(self, scope=""):
        """Scan scene dependencies and display results."""
        scope = scope.strip() or "all"
        self._log_activity("Scanning dependencies ({})...".format(scope), "action")
        try:
            from synapse.panel.dependency_map import scan_dependencies, format_deps_html
            report = scan_dependencies(scope)
            self._chat_display.append(format_deps_html(report))
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())
            self._log_activity(report.summary, "info")
            # Log to journal
            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/deps", report.summary)
            except Exception:
                pass
            # Offer Claude analysis if missing deps found
            if report.missing_count:
                self._sys(
                    "{} missing file{}. Ask me to help resolve them.".format(
                        report.missing_count,
                        "s" if report.missing_count != 1 else "",
                    )
                )
        except ImportError:
            self._sys("Dependency scanner unavailable (synapse.panel.dependency_map not found)")
        except Exception as e:
            self._sys("Dependency scan error: " + str(e))

    def _do_profile(self, network=""):
        """Profile a network for cook-time bottlenecks."""
        network = network.strip()
        label = network if network else "current network"
        self._log_activity("Profiling {}...".format(label), "action")
        try:
            from synapse.panel.performance_profiler import (
                profile_network, format_profile_html, build_profile_messages,
            )
            report = profile_network(network)
            self._chat_display.append(format_profile_html(report))
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())
            self._log_activity(report.summary, "info")
            # Log to journal
            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/profile", report.summary)
            except Exception:
                pass
            # If bottlenecks found, launch Claude worker for deeper analysis
            if report.bottlenecks:
                messages = build_profile_messages(report)
                system_prompt = self._build_memory_system_prompt(
                    "You are SYNAPSE, a Houdini performance advisor."
                )
                self._launch_worker(messages, system_prompt)
        except ImportError:
            self._sys("Profiler unavailable (synapse.panel.performance_profiler not found)")
        except Exception as e:
            self._sys("Profile error: " + str(e))

    def _do_save_shot(self, note=""):
        """Save a session snapshot to disk."""
        self._log_activity("Saving session snapshot...", "action")
        try:
            from synapse.panel.save_shot import save_shot, format_save_html
            snapshot = save_shot(note, self._messages, self._login_data)
            self._chat_display.append(format_save_html(snapshot))
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())
            self._log_activity("Snapshot saved: " + snapshot.save_path, "success")
            # Log to journal
            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/save-shot", "saved to " + snapshot.save_path)
            except Exception:
                pass
        except ImportError:
            self._sys("Save-shot unavailable (synapse.panel.save_shot not found)")
        except Exception as e:
            self._sys("Save-shot error: " + str(e))

    def _do_shots(self, arg=""):
        """List or search saved session snapshots."""
        try:
            from synapse.panel.save_shot import (
                parse_save_command, list_snapshots, format_snapshots_html,
            )
            parsed = parse_save_command("/shots " + arg)
            if parsed.get("action") == "search":
                query = parsed.get("query", "").lower()
                snapshots = list_snapshots()
                snapshots = [
                    s for s in snapshots
                    if query in s.get("note_preview", "").lower()
                    or query in s.get("filename", "").lower()
                ]
            else:
                snapshots = list_snapshots()
            self._chat_display.append(format_snapshots_html(snapshots))
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())
            self._log_activity("{} snapshot(s) found".format(len(snapshots)), "info")
            # Log to journal
            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/shots", "{} snapshots".format(len(snapshots)))
            except Exception:
                pass
        except ImportError:
            self._sys("Shots unavailable (synapse.panel.save_shot not found)")
        except Exception as e:
            self._sys("Shots error: " + str(e))

    # ── Explain Mode ─────────────────────────────────────────

    def _do_explain(self, arg=""):
        """Explain a selected node or network data flow via Claude."""
        try:
            from synapse.panel.explain_mode import (
                gather_node_context, gather_network_context,
                build_explain_prompt, build_explain_messages,
            )
        except ImportError as e:
            self._sys("Explain mode unavailable: " + str(e))
            return

        arg = arg.strip()

        # Determine mode: network path (starts with /) or node
        is_network = False
        if arg.startswith("/"):
            # Check if this resolves to a network (container with children)
            try:
                node = hou.node(arg)
                if node is not None and len(node.children()) > 0:
                    is_network = True
            except Exception:
                pass

        if is_network:
            context = gather_network_context(arg)
            mode = "network"
        else:
            # Node mode: use arg as path, or fall back to selection
            node_path = arg
            if not node_path:
                try:
                    sel = hou.selectedNodes()
                    if sel:
                        node_path = sel[0].path()
                except Exception:
                    pass
            if not node_path:
                self._sys("Select a node first, or type /explain &lt;node_path&gt;")
                return
            context = gather_node_context(node_path)
            mode = "node"

        if context.get("error"):
            self._sys(context["error"])
            return

        # Display user intent
        label_color = SILVER if _HAS_DESIGN else "#999999"
        label_sz = SIZE_LABEL if _HAS_DESIGN else 9
        target = context.get("network_path") or context.get("node_path", "")
        self._chat_display.append(
            '<div style="margin: 8px 0 4px 0;">'
            '<span style="color: {}; font-size: {}px; letter-spacing: 1px;">'
            'YOU</span></div>'
            '<div style="margin: 0 0 8px 10px;">/explain {}</div>'.format(
                label_color, label_sz, target,
            )
        )

        # Build prompts and launch worker
        explain_prompt = build_explain_prompt(context, mode)
        messages = build_explain_messages(context, mode)

        # Separate system message from user messages
        sys_content = explain_prompt
        user_messages = [m for m in messages if m["role"] != "system"]

        try:
            from synapse.panel.system_prompt import build_system_prompt
            base = build_system_prompt(self._gather_context())
        except ImportError:
            base = "You are SYNAPSE, an AI co-pilot inside Houdini 21."
        system_prompt = self._build_memory_system_prompt(base + "\n\n" + sys_content)

        self._launch_worker(user_messages, system_prompt)

        # Log to journal
        try:
            from synapse.panel.session_journal import get_journal
            get_journal().log_command("/explain", "{} ({})".format(target, mode))
        except Exception:
            pass

    # ── Network Trace ────────────────────────────────────────

    def _do_trace(self, network_path=""):
        """Trace data flow through a network and display results."""
        try:
            from synapse.panel.network_trace import trace_network, format_trace_html
        except ImportError as e:
            self._sys("Network trace unavailable: " + str(e))
            return

        network_path = network_path.strip()
        report = trace_network(network_path)
        self._chat_display.append(format_trace_html(report))
        sb = self._chat_display.verticalScrollBar()
        sb.setValue(sb.maximum())

        self._log_activity("Trace: " + report.summary, "info")

        # Log to journal
        try:
            from synapse.panel.session_journal import get_journal
            get_journal().log_command("/trace", report.summary)
        except Exception:
            pass

    # ── VEX Tutor ────────────────────────────────────────────

    def _do_vex(self, arg=""):
        """VEX tutor: explain, help, or write VEX code."""
        try:
            from synapse.panel.vex_tutor import (
                parse_vex_command, VEX_REFERENCE,
                gather_wrangle_context, build_vex_messages,
                format_vex_reference_html,
            )
        except ImportError as e:
            self._sys("VEX tutor unavailable: " + str(e))
            return

        parsed = parse_vex_command("/vex " + arg)
        mode = parsed["mode"]
        vex_arg = parsed["arg"]

        # Display user intent
        label_color = SILVER if _HAS_DESIGN else "#999999"
        label_sz = SIZE_LABEL if _HAS_DESIGN else 9
        display_text = "/vex {}".format(arg) if arg else "/vex"
        self._chat_display.append(
            '<div style="margin: 8px 0 4px 0;">'
            '<span style="color: {}; font-size: {}px; letter-spacing: 1px;">'
            'YOU</span></div>'
            '<div style="margin: 0 0 8px 10px;">{}</div>'.format(
                label_color, label_sz, display_text,
            )
        )

        # Show usage if bare /vex help with no argument
        if mode == "help" and not vex_arg:
            self._sys(
                "<b>VEX Tutor commands:</b><br>"
                "  /vex explain -- Explain VEX in selected wrangle<br>"
                "  /vex help &lt;function&gt; -- Quick reference for a VEX function<br>"
                "  /vex write &lt;description&gt; -- Generate VEX from a description<br>"
                "  /vex &lt;function&gt; -- Shortcut for /vex help &lt;function&gt;"
            )
            return

        # Gather wrangle context for all modes
        context = gather_wrangle_context()

        # If help mode and function is in reference, show inline card first
        if mode == "help" and vex_arg in VEX_REFERENCE:
            ref = VEX_REFERENCE[vex_arg]
            self._chat_display.append(format_vex_reference_html(vex_arg, ref))
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())

        # For explain mode, check we have code
        if mode == "explain" and not context.get("vex_code"):
            self._sys("Select a wrangle node with VEX code first, then try /vex explain again.")
            return

        # Build messages and launch Claude
        messages = build_vex_messages(mode, vex_arg, context)
        # Separate system from user messages
        sys_msgs = [m for m in messages if m["role"] == "system"]
        user_msgs = [m for m in messages if m["role"] != "system"]
        sys_content = sys_msgs[0]["content"] if sys_msgs else ""

        try:
            from synapse.panel.system_prompt import build_system_prompt
            base = build_system_prompt(self._gather_context())
        except ImportError:
            base = "You are SYNAPSE, an AI co-pilot inside Houdini 21."
        system_prompt = self._build_memory_system_prompt(base + "\n\n" + sys_content)

        self._launch_worker(user_msgs, system_prompt)

        # Log to journal
        try:
            from synapse.panel.session_journal import get_journal
            get_journal().log_command("/vex", "{} {}".format(mode, vex_arg).strip())
        except Exception:
            pass

    # ── Recipe Book ──────────────────────────────────────────

    def _do_recipes(self, arg=""):
        """Browse and build network recipes."""
        try:
            from synapse.panel.recipe_book import (
                parse_recipe_command, format_categories_html,
                format_category_html, format_recipe_html,
                search_recipes, build_recipe_messages, get_recipe,
            )
        except ImportError as e:
            self._sys("Recipe book unavailable: " + str(e))
            return

        parsed = parse_recipe_command("/recipes " + arg)
        action = parsed["action"]

        if action == "list":
            self._chat_display.append(format_categories_html())
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())
        elif action == "category":
            self._chat_display.append(format_category_html(parsed["category"]))
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())
        elif action == "detail":
            self._chat_display.append(
                format_recipe_html(parsed["category"], parsed["recipe"])
            )
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())
        elif action == "search":
            results = search_recipes(parsed["query"])
            if not results:
                self._sys("No recipes found matching '{}'.".format(parsed["query"]))
            else:
                color = SILVER if _HAS_DESIGN else "#999999"
                lines = [
                    '<div style="color: {};">'.format(
                        BONE if _HAS_DESIGN else "#CCCCCC"
                    ),
                    "<b>Search results for '{}':</b><br>".format(parsed["query"]),
                ]
                for cat, name, title, match_ctx in results:
                    lines.append(
                        "  <b>{}/{}</b> -- {}<br>".format(cat, name, title)
                    )
                lines.append(
                    '<span style="color: {};">Type /recipes &lt;category&gt; '
                    "&lt;recipe&gt; for details.</span>".format(color)
                )
                lines.append("</div>")
                self._chat_display.append("\n".join(lines))
                sb = self._chat_display.verticalScrollBar()
                sb.setValue(sb.maximum())
        elif action == "build":
            category = parsed["category"]
            recipe_name = parsed["recipe"]
            recipe = get_recipe(category, recipe_name)
            if recipe is None:
                self._sys(
                    "Recipe '{}/{}' not found. Type /recipes to browse.".format(
                        category, recipe_name
                    )
                )
                return

            # Display user intent
            label_color = SILVER if _HAS_DESIGN else "#999999"
            label_sz = SIZE_LABEL if _HAS_DESIGN else 9
            self._chat_display.append(
                '<div style="margin: 8px 0 4px 0;">'
                '<span style="color: {}; font-size: {}px; letter-spacing: 1px;">'
                'YOU</span></div>'
                '<div style="margin: 0 0 8px 10px;">'
                '/recipes build {} {}</div>'.format(
                    label_color, label_sz, category, recipe_name,
                )
            )

            context = self._gather_context()
            parent_path = context.get("network", "/obj/geo1")
            messages = build_recipe_messages(
                category, recipe_name, {"parent_path": parent_path}
            )
            if not messages:
                self._sys("Could not build messages for this recipe.")
                return

            try:
                from synapse.panel.system_prompt import build_system_prompt
                base = build_system_prompt(context)
            except ImportError:
                base = "You are SYNAPSE, an AI co-pilot inside Houdini 21."
            system_prompt = self._build_memory_system_prompt(base)

            self._launch_worker(messages, system_prompt)

            self._log_activity(
                "Building recipe: {}/{}".format(category, recipe_name), "action"
            )

        # Log to journal
        try:
            from synapse.panel.session_journal import get_journal
            get_journal().log_command(
                "/recipes", "{} {}".format(action, arg).strip()
            )
        except Exception:
            pass

    # ── APEX Rigging Tools ────────────────────────────────────

    def _do_apex(self, arg=""):
        """APEX rigging tools: explain, trace, recipes, build, overview, concept, migrate."""
        parts = arg.strip().split(None, 1) if arg else []
        subcmd = parts[0].lower() if parts else ""
        subarg = parts[1] if len(parts) > 1 else ""

        # Display user intent
        label_color = SILVER if _HAS_DESIGN else "#999999"
        label_sz = SIZE_LABEL if _HAS_DESIGN else 9
        display_text = "/apex {}".format(arg) if arg else "/apex"
        self._chat_display.append(
            '<div style="margin: 8px 0 4px 0;">'
            '<span style="color: {}; font-size: {}px; letter-spacing: 1px;">'
            'YOU</span></div>'
            '<div style="margin: 0 0 8px 10px;">{}</div>'.format(
                label_color, label_sz, display_text,
            )
        )

        if not subcmd or subcmd == "help":
            color = SILVER if _HAS_DESIGN else "#999999"
            sz = SIZE_SMALL if _HAS_DESIGN else 11
            help_lines = [
                "<b>APEX Rigging Tools:</b>",
                "",
                "  /apex explain [node] -- Explain any APEX node",
                "  /apex trace [node] -- Trace an APEX graph's execution",
                "  /apex recipes -- Browse APEX rigging recipes",
                "  /apex recipes &lt;name&gt; -- Show recipe details",
                "  /apex build &lt;recipe&gt; -- Build an APEX recipe",
                "  /apex overview -- Introduction to APEX",
                "  /apex concept &lt;name&gt; -- Look up an APEX concept",
                "  /apex migrate -- KineFX to APEX migration guide",
            ]
            html_out = '<div style="color: {}; font-size: {}px; margin: 4px 0;">{}</div>'.format(
                color, sz, "<br>".join(help_lines),
            )
            self._chat_display.append(html_out)
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())

        elif subcmd == "explain":
            try:
                from synapse.panel.apex_explainer import (
                    gather_apex_context, build_apex_explain_prompt,
                    build_apex_messages,
                )
            except ImportError as e:
                self._sys("APEX explainer unavailable: " + str(e))
                return

            node_path = subarg.strip()
            if not node_path:
                try:
                    sel = hou.selectedNodes()
                    if sel:
                        node_path = sel[0].path()
                except Exception:
                    pass
            if not node_path:
                self._sys("Select an APEX node first, or type /apex explain &lt;node_path&gt;")
                return

            context = gather_apex_context(node_path)
            if context.get("errors") and not context.get("is_apex_node"):
                for err in context["errors"]:
                    self._sys(str(err))
                return

            explain_prompt = build_apex_explain_prompt(context)
            messages = build_apex_messages(context)

            try:
                from synapse.panel.system_prompt import build_system_prompt
                base = build_system_prompt(self._gather_context())
            except ImportError:
                base = "You are SYNAPSE, an AI co-pilot inside Houdini 21."
            system_prompt = self._build_memory_system_prompt(base + "\n\n" + explain_prompt)

            self._launch_worker(messages, system_prompt)

            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/apex", "explain {}".format(node_path))
            except Exception:
                pass

        elif subcmd == "trace":
            try:
                from synapse.panel.apex_trace import (
                    trace_apex_graph, format_apex_trace_html,
                    build_apex_trace_prompt, build_apex_trace_messages,
                )
            except ImportError as e:
                self._sys("APEX trace unavailable: " + str(e))
                return

            invoke_path = subarg.strip()
            if not invoke_path:
                try:
                    sel = hou.selectedNodes()
                    if sel:
                        invoke_path = sel[0].path()
                except Exception:
                    pass
            if not invoke_path:
                self._sys("Select an APEX Invoke node first, or type /apex trace &lt;node_path&gt;")
                return

            trace = trace_apex_graph(invoke_path)

            # Display trace HTML inline
            self._chat_display.append(format_apex_trace_html(trace))
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())

            # Also send to Claude for interpretation
            trace_prompt = build_apex_trace_prompt(trace)
            messages = build_apex_trace_messages(trace)

            try:
                from synapse.panel.system_prompt import build_system_prompt
                base = build_system_prompt(self._gather_context())
            except ImportError:
                base = "You are SYNAPSE, an AI co-pilot inside Houdini 21."
            system_prompt = self._build_memory_system_prompt(base + "\n\n" + trace_prompt)

            self._launch_worker(messages, system_prompt)

            self._log_activity("APEX trace: " + trace.summary, "info")

            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/apex", "trace {}".format(invoke_path))
            except Exception:
                pass

        elif subcmd == "recipes":
            if subarg:
                # Show specific recipe detail
                try:
                    from synapse.panel.apex_recipes import format_apex_recipe_detail_html
                except ImportError as e:
                    self._sys("APEX recipes unavailable: " + str(e))
                    return
                self._chat_display.append(format_apex_recipe_detail_html(subarg.strip()))
            else:
                # Show all APEX recipes overview
                try:
                    from synapse.panel.apex_recipes import format_apex_recipes_html
                except ImportError as e:
                    self._sys("APEX recipes unavailable: " + str(e))
                    return
                self._chat_display.append(format_apex_recipes_html())
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())

            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/apex", "recipes {}".format(subarg).strip())
            except Exception:
                pass

        elif subcmd == "build":
            if not subarg:
                self._sys("Usage: /apex build &lt;recipe_name&gt;")
                return

            try:
                from synapse.panel.apex_recipes import (
                    get_apex_recipe, build_apex_recipe_messages,
                )
            except ImportError as e:
                self._sys("APEX recipes unavailable: " + str(e))
                return

            recipe_name = subarg.strip()
            recipe = get_apex_recipe(recipe_name)
            if recipe is None:
                self._sys(
                    "APEX recipe '{}' not found. Type /apex recipes to browse.".format(
                        recipe_name
                    )
                )
                return

            context = self._gather_context()
            parent_path = context.get("network", "/obj/geo1")
            messages = build_apex_recipe_messages(
                recipe_name, {"parent_path": parent_path}
            )
            if not messages:
                self._sys("Could not build messages for this recipe.")
                return

            try:
                from synapse.panel.system_prompt import build_system_prompt
                base = build_system_prompt(context)
            except ImportError:
                base = "You are SYNAPSE, an AI co-pilot inside Houdini 21."
            system_prompt = self._build_memory_system_prompt(base)

            self._launch_worker(messages, system_prompt)

            self._log_activity(
                "Building APEX recipe: {}".format(recipe_name), "action"
            )

            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/apex", "build {}".format(recipe_name))
            except Exception:
                pass

        elif subcmd == "overview":
            try:
                from synapse.panel.apex_explainer import build_apex_overview_prompt
            except ImportError as e:
                self._sys("APEX explainer unavailable: " + str(e))
                return

            overview_prompt = build_apex_overview_prompt()
            messages = [{"role": "user", "content": "Give me an introduction to APEX in Houdini 21."}]

            try:
                from synapse.panel.system_prompt import build_system_prompt
                base = build_system_prompt(self._gather_context())
            except ImportError:
                base = "You are SYNAPSE, an AI co-pilot inside Houdini 21."
            system_prompt = self._build_memory_system_prompt(base + "\n\n" + overview_prompt)

            self._launch_worker(messages, system_prompt)

            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/apex", "overview")
            except Exception:
                pass

        elif subcmd == "concept":
            if not subarg:
                # List all concept names
                try:
                    from synapse.panel.apex_explainer import APEX_CONCEPTS
                except ImportError as e:
                    self._sys("APEX explainer unavailable: " + str(e))
                    return
                names = sorted(APEX_CONCEPTS.keys())
                color = SILVER if _HAS_DESIGN else "#999999"
                sz = SIZE_SMALL if _HAS_DESIGN else 11
                lines = ["<b>APEX Concepts:</b><br>"]
                for name in names:
                    title = APEX_CONCEPTS[name].get("title", name)
                    lines.append("  <b>{}</b> -- {}<br>".format(name, title))
                lines.append(
                    '<br><span style="color: {}; font-size: {}px;">'
                    "Type /apex concept &lt;name&gt; for details.</span>".format(color, sz)
                )
                self._chat_display.append(
                    '<div style="color: {};">{}</div>'.format(
                        BONE if _HAS_DESIGN else "#CCCCCC",
                        "\n".join(lines),
                    )
                )
            else:
                try:
                    from synapse.panel.apex_explainer import format_concept_html, APEX_CONCEPTS
                except ImportError as e:
                    self._sys("APEX explainer unavailable: " + str(e))
                    return
                concept_key = subarg.strip().lower()
                self._chat_display.append(format_concept_html(concept_key))
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())

            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/apex", "concept {}".format(subarg).strip())
            except Exception:
                pass

        elif subcmd == "migrate":
            try:
                from synapse.panel.apex_recipes import KINEFX_MIGRATION_GUIDE
            except ImportError as e:
                self._sys("APEX recipes unavailable: " + str(e))
                return

            # Format migration guide as styled HTML
            import html as _html_mod
            escaped = _html_mod.escape(KINEFX_MIGRATION_GUIDE)
            escaped = escaped.replace("\n", "<br>")
            mono = FONT_MONO if _HAS_DESIGN else "monospace"
            sz = SIZE_SMALL if _HAS_DESIGN else 11
            self._chat_display.append(
                '<div style="font-family: {}; font-size: {}px; color: {}; '
                'padding: 8px; line-height: 1.6;">{}</div>'.format(
                    mono, sz,
                    BONE if _HAS_DESIGN else "#CCCCCC",
                    escaped,
                )
            )
            sb = self._chat_display.verticalScrollBar()
            sb.setValue(sb.maximum())

            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/apex", "migrate")
            except Exception:
                pass

        else:
            self._sys(
                "Unknown APEX subcommand: {}. Type /apex help for available commands.".format(
                    subcmd
                )
            )

    # ── Welcome Experience ───────────────────────────────────

    def _show_welcome(self):
        """Display first-time welcome message in the chat area."""
        signal = SIGNAL if _HAS_DESIGN else "#00D4FF"
        text = BONE if _HAS_DESIGN else "#CCCCCC"
        dim = SILVER if _HAS_DESIGN else "#999999"
        sz = SIZE_BODY if _HAS_DESIGN else 13
        sz_sm = SIZE_SMALL if _HAS_DESIGN else 11
        html = (
            '<div style="color: {text}; font-size: {sz}px; margin: 12px 8px;">'
            '<b style="color: {signal}; font-size: {sz_lg}px;">SYNAPSE</b>'
            '<br><br>'
            "I'm here to help you build, learn, and ship."
            '<br><br>'
            '<span style="color: {dim};">Three things to try:</span>'
            '<br>'
            '<b style="color: {signal};">Tell me what to build</b> '
            '-- "create a grid with mountain displacement"'
            '<br>'
            '<b style="color: {signal};">Ask me to explain</b> '
            '-- select a node and type <b>/explain</b>'
            '<br>'
            '<b style="color: {signal};">Check your work</b> '
            '-- <b>/diagnose</b> scans for problems'
            '<br><br>'
            '<span style="color: {dim}; font-size: {sz_sm}px;">'
            'Type anything to get started. <b>/help</b> shows all commands.'
            '</span>'
            '</div>'
        ).format(
            text=text, signal=signal, dim=dim,
            sz=sz, sz_sm=sz_sm,
            sz_lg=SIZE_TITLE if _HAS_DESIGN else 16,
        )
        self._chat_display.append(html)

    def _chat(self, user_text):
        """Send a message to Claude and stream the response."""
        label_color = SILVER if _HAS_DESIGN else "#999999"
        label_sz = SIZE_LABEL if _HAS_DESIGN else 9

        # Build image content block if an image is attached
        image_block = None
        image_html = ""
        if self._pending_image_path:
            try:
                from synapse.panel.image_prep import prepare_image_block
                result = prepare_image_block(self._pending_image_path)
                image_block = result["block"]
                fname = os.path.basename(self._pending_image_path)

                if result["resized"]:
                    w, h = result["dimensions"]
                    self._log_activity(
                        "{} resized to {}x{} ({:.0f}KB -> {:.0f}KB)".format(
                            fname, w, h,
                            result["orig_bytes"] / 1024,
                            result["sent_bytes"] / 1024,
                        ), "info"
                    )

                # Inline thumbnail via QTextDocument resource
                thumb = QtGui.QPixmap(self._pending_image_path)
                if not thumb.isNull() and thumb.width() > 200:
                    thumb = thumb.scaledToWidth(
                        200, QtCore.Qt.SmoothTransformation
                    )
                if not thumb.isNull():
                    res_name = "attach_{}".format(int(time.time() * 1000))
                    self._chat_display.document().addResource(
                        QtGui.QTextDocument.ImageResource,
                        QtCore.QUrl(res_name),
                        thumb,
                    )
                    image_html = (
                        '<div style="margin: 0 0 4px 10px;">'
                        '<img src="{src}" />'
                        '<br/><span style="color: {c}; font-size: {sz}px;">'
                        '{fn}</span></div>'
                    ).format(
                        src=res_name,
                        c=SLATE if _HAS_DESIGN else "#555555",
                        sz=SIZE_SMALL if _HAS_DESIGN else 11,
                        fn=fname,
                    )
            except Exception as exc:
                self._log_activity(
                    "Couldn't read image: {}".format(exc), "warning"
                )

            # Clear the pending image state
            self._pending_image_path = None
            self._image_preview.setVisible(False)
            self._image_thumb.clear()
            self._image_name.clear()

        # Display user message in chat
        user_html = (
            '<div style="margin: 8px 0 4px 0;">'
            '<span style="color: {}; font-size: {}px; letter-spacing: 1px;">'
            'YOU</span></div>'
        ).format(label_color, label_sz)
        if image_html:
            user_html += image_html
        if user_text:
            user_html += (
                '<div style="margin: 0 0 8px 10px;">{}</div>'
            ).format(user_text.replace("\n", "<br>"))
        self._chat_display.append(user_html)

        # Build message content (multi-part if image attached)
        if image_block:
            content = []
            content.append(image_block)
            if user_text:
                content.append({"type": "text", "text": user_text})
        else:
            content = user_text

        # Append to conversation history
        self._messages.append({"role": "user", "content": content})

        # Build system prompt
        try:
            from synapse.panel.system_prompt import build_system_prompt
            system_prompt = build_system_prompt(self._gather_context())
        except ImportError:
            system_prompt = (
                "You are SYNAPSE, an AI co-pilot inside Houdini 21. "
                "Help the artist with VFX tasks."
            )
        system_prompt = self._build_memory_system_prompt(system_prompt)

        # MOE: Filter tools by domain and specialize prompt
        filtered_tools = None
        user_text_for_routing = user_text if isinstance(content, str) else user_text
        try:
            from synapse.panel.tool_filter import filter_tools
            from synapse.panel.tool_bridge import get_anthropic_tools
            all_tools = get_anthropic_tools()
            filtered_tools, routing_decision = filter_tools(
                user_text_for_routing, all_tools,
            )
            # Specialize system prompt based on routing
            if routing_decision is not None:
                try:
                    from synapse.panel.agent_prompts import build_specialized_prompt
                    system_prompt = build_specialized_prompt(
                        system_prompt, routing_decision, self._gather_context(),
                    )
                except ImportError:
                    pass
                # Log routing decision (Phase 5) + surface agent in activity
                try:
                    from synapse.panel.routing_log import get_routing_log
                    get_routing_log().log_decision(routing_decision)
                    if hasattr(routing_decision, "primary"):
                        agent_name = (
                            routing_decision.primary.value
                            if hasattr(routing_decision.primary, "value")
                            else str(routing_decision.primary)
                        )
                        method = getattr(routing_decision, "method", "scored")
                        self._log_activity(
                            "Routed to {} ({})".format(agent_name, method),
                            "info",
                        )
                except Exception:
                    pass
        except ImportError:
            filtered_tools = None

        self._launch_worker(self._messages, system_prompt, tools=filtered_tools)

    def _on_token(self, text):
        """Handle a streamed text token from the worker."""
        self._streaming_text += text
        # Move cursor to end and insert text
        cursor = self._chat_display.textCursor()
        cursor.movePosition(QtGui.QTextCursor.End)
        cursor.insertText(text)
        self._chat_display.setTextCursor(cursor)
        sb = self._chat_display.verticalScrollBar()
        sb.setValue(sb.maximum())

    def _on_done(self):
        """Handle stream completion."""
        # Close the streaming div
        cursor = self._chat_display.textCursor()
        cursor.movePosition(QtGui.QTextCursor.End)
        cursor.insertHtml("</div>")
        self._chat_display.setTextCursor(cursor)

        self._send_btn.setEnabled(True)
        self._stop_btn.setVisible(False)
        self._attach_btn.setVisible(True)

        # Sync conversation history from the worker (includes tool loop turns)
        if self._worker:
            self._messages = self._worker.get_messages()

        # Session integrity check (best-effort, never blocks)
        try:
            from synapse.panel.session_integrity import get_tracker
            tracker = get_tracker()
            if tracker.should_warn():
                self._log_activity(
                    "Integrity: {} violations detected (fidelity {:.0%})".format(
                        tracker.violation_count, tracker.session_fidelity,
                    ), "warning"
                )
            if tracker.should_evolve(
                getattr(self, "_login_data", None)
            ):
                # Show evolution stage with Pokémon name
                try:
                    from synapse.panel.agent_health import get_evolution_display
                    evo = get_evolution_display(getattr(self, "_login_data", None))
                    self._log_activity(
                        "Memory evolution recommended ({} -> next stage)".format(
                            evo.get("label", "unknown"),
                        ), "info",
                    )
                except Exception:
                    self._log_activity(
                        "Memory evolution recommended -- structured data accumulated",
                        "info",
                    )
        except Exception:
            pass

        # Surface critical advisor recommendations (best-effort)
        try:
            from synapse.panel.agent_health import get_agent_health
            health = get_agent_health()
            if health and health.get("recommendations"):
                for rec in health["recommendations"]:
                    if getattr(rec, "severity", "") == "critical":
                        self._log_activity(
                            "Advisor: {} -- {}".format(
                                getattr(rec, "target", ""),
                                getattr(rec, "rationale", ""),
                            ), "warning",
                        )
        except Exception:
            pass

    def _on_error(self, error_msg):
        """Handle stream error with optional translation."""
        # Try to translate the error into a coaching-tone explanation
        try:
            from synapse.panel.error_translator import translate_error, format_translation_html
            translation = translate_error(error_msg)
            if translation:
                self._chat_display.append(format_translation_html(translation))
                sb = self._chat_display.verticalScrollBar()
                sb.setValue(sb.maximum())
                self._send_btn.setEnabled(True)
                self._stop_btn.setVisible(False)
                self._attach_btn.setVisible(True)
                # Log to journal
                try:
                    from synapse.panel.session_journal import get_journal
                    get_journal().log_event("ERROR", error_msg[:200])
                except Exception:
                    pass
                return
        except ImportError:
            pass

        # No pattern match or translator unavailable -- show raw error
        error_color = ERROR if _HAS_DESIGN else "#FF3D71"
        self._chat_display.append(
            '<div style="color: {}; margin: 4px 0 8px 10px;">'
            'We hit a snag: {}</div>'.format(error_color, error_msg[:300])
        )
        self._send_btn.setEnabled(True)
        self._stop_btn.setVisible(False)
        self._attach_btn.setVisible(True)
        # Log to journal
        try:
            from synapse.panel.session_journal import get_journal
            get_journal().log_event("ERROR", error_msg[:200])
        except Exception:
            pass

    def _on_tool_status(self, tool_name, status, summary=""):
        """Display a compact inline indicator showing tool execution status."""
        icons = {"running": "\u2699", "done": "\u2713", "error": "\u2717"}
        colors = {
            "running": FIRE if _HAS_DESIGN else "#FF6B35",
            "done": GROW if _HAS_DESIGN else "#00E676",
            "error": ERROR if _HAS_DESIGN else "#FF3D71",
        }
        display = tool_name.replace("houdini_", "").replace("synapse_", "")
        display = display.replace("_", " ").title()
        text_sec = SILVER if _HAS_DESIGN else "#999999"
        color = colors.get(status, text_sec)
        icon = icons.get(status, "")
        sz = SIZE_SMALL if _HAS_DESIGN else 11
        html = (
            '<div style="margin:2px 0 2px 20px; padding:3px 10px; '
            'font-size:{}px; color:{}; '
            'border-left:2px solid {};">'
            '{} {}'
            '</div>'
        ).format(sz, color, color, icon, display)
        self._chat_display.append(html)
        sb = self._chat_display.verticalScrollBar()
        sb.setValue(sb.maximum())

        # Log completed/failed tool executions to the session journal
        if status in ("done", "error"):
            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_tool(
                    tool_name, {"summary": summary} if summary else {},
                    None,
                    error=("Tool error" if status == "error" else None),
                )
            except Exception:
                pass

    # ── Server Controls ──────────────────────────────────

    def _on_connect_toggle(self):
        """Start or stop the WebSocket server."""
        if self._server and getattr(self._server, "_running", False):
            # Stop the server
            self._stop_server()
        else:
            # Start the server
            self._start_server()

    # ── Sprint 5: Command Palette ───────────────────────────

    def _show_palette(self):
        """Open the fuzzy-search command palette (Ctrl+K)."""
        try:
            from synapse.panel.command_palette import CommandPaletteWidget
        except ImportError:
            self._sys("Command palette not available")
            return

        if self._palette is None:
            self._palette = CommandPaletteWidget(parent=self)
            self._palette.command_selected.connect(self._on_palette_command)

        # Feed recent journal entries if available
        recent = []
        try:
            from synapse.panel.session_journal import get_journal
            recent = get_journal().get_entries(10)
        except Exception:
            pass

        self._palette.show_palette(recent)

    def _on_palette_command(self, command):
        """Handle a command selected from the palette."""
        self._route_cmd(command)

    # ── Sprint 5: Bookmarks ──────────────────────────────────

    def _do_bookmark(self, arg=""):
        """Handle /bookmark commands."""
        try:
            from synapse.panel.bookmarks import (
                get_bookmark_manager, parse_bookmark_command,
                format_bookmarks_html,
            )
        except ImportError:
            self._sys("Bookmarks not available")
            return

        parsed = parse_bookmark_command(
            "/bookmark " + arg if arg else "/bookmark"
        )
        manager = get_bookmark_manager()

        if parsed["action"] == "list":
            bookmarks = manager.get_all()
            html = format_bookmarks_html(bookmarks)
            self._chat_display.append(html)

        elif parsed["action"] == "add":
            # Bookmark the last assistant message
            preview = ""
            msg_idx = len(self._messages) - 1
            if self._messages:
                last = self._messages[-1]
                if isinstance(last.get("content"), str):
                    preview = last["content"][:100]
                elif isinstance(last.get("content"), list):
                    for block in last["content"]:
                        if isinstance(block, dict) and block.get("type") == "text":
                            preview = block["text"][:100]
                            break

            bookmark = manager.add(parsed["label"], msg_idx, preview)
            self._sys("Bookmarked: {}".format(bookmark.label))

            # Log to journal
            try:
                from synapse.panel.session_journal import get_journal
                get_journal().log_command("/bookmark", bookmark.label)
            except Exception:
                pass

        elif parsed["action"] == "search":
            results = manager.search(parsed["query"])
            html = format_bookmarks_html(results, parsed["query"])
            self._chat_display.append(html)

        elif parsed["action"] == "remove":
            if manager.remove(parsed["id"]):
                self._sys("Bookmark removed")
            else:
                self._sys("Bookmark not found: " + parsed["id"])

        sb = self._chat_display.verticalScrollBar()
        sb.setValue(sb.maximum())

    # ── Sprint 5: Results Display ────────────────────────────

    def _show_results(self, html, title=""):
        """Show structured results in the chat with a visual separator."""
        separator = '<div style="margin:8px 0; border-top:1px solid #484848;"></div>'
        if title:
            header = (
                '<div style="font-weight:bold; color:#e8833a;'
                ' margin:4px 0;">{}</div>'.format(title)
            )
            self._chat_display.append(separator + header + html)
        else:
            self._chat_display.append(separator + html)

        sb = self._chat_display.verticalScrollBar()
        sb.setValue(sb.maximum())

    def _start_server(self):
        """Start the Synapse WebSocket server."""
        # Check for zombie server first
        existing = _find_running_server()
        if existing:
            self._server = existing
            hou.session._synapse_server = existing
            port = getattr(existing, "_actual_port", _PORT)
            self._set_status("connected", "port {}".format(port))
            self._log_activity("Found running server on port {}".format(port), "success")
            self._health_timer.start()
            return

        SynapseServer = _get_server_module()
        if SynapseServer is None:
            self._log_activity(
                "Couldn't import SynapseServer -- is the synapse package installed?",
                "error",
            )
            self._set_status("error", "import failed")
            return

        self._log_activity("Starting server...", "action")
        self._set_status("executing", "Starting")

        try:
            self._server = SynapseServer(host="localhost", port=_PORT)
            self._server.start()
            hou.session._synapse_server = self._server
        except Exception as e:
            self._log_activity("Server failed to start: {}".format(e), "error")
            self._set_status("error", str(e)[:40])
            self._server = None
            return

        # Give the background thread a moment to bind
        port = getattr(self._server, "_actual_port", _PORT)
        self._set_status("connected", "port {}".format(port))
        self._log_activity(
            "Server listening on port {}".format(port), "success"
        )
        self._health_timer.start()

    def _stop_server(self):
        """Stop the Synapse WebSocket server."""
        self._health_timer.stop()
        if self._server:
            self._log_activity("Stopping server...", "action")
            try:
                self._server.stop()
            except Exception as e:
                self._log_activity("Stop error: {}".format(e), "warning")
            self._server = None
        self._set_status("disconnected")
        self._log_activity("Server stopped", "warning")

    def _poll_server_health(self):
        """Periodic check that the server is still running + hip change detection."""
        # Check if hip file changed (re-login if needed)
        try:
            current_hip = hou.hipFile.path()
            from synapse.panel.shot_login import check_login_needed
            if check_login_needed(current_hip, self._last_hip):
                self._do_shot_login()
        except Exception:
            pass

        # Sprint 5: Update context bar on each health poll
        if self._context_bar_widget is not None:
            try:
                from synapse.panel.context_bar import (
                    update_context, update_context_bar_widget,
                )
                self._context_bar_state = update_context(
                    self._login_data, self._last_diagnosis,
                )
                update_context_bar_widget(
                    self._context_bar_widget, self._context_bar_state,
                )
                # Re-wire any new quick-action buttons
                for btn in self._context_bar_widget.findChildren(
                    QtWidgets.QPushButton,
                ):
                    cmd = btn.property("command")
                    if cmd:
                        try:
                            btn.clicked.disconnect()
                        except Exception:
                            pass
                        btn.clicked.connect(
                            lambda checked=False, c=cmd: self._route_cmd(c)
                        )
            except Exception:
                pass

        # Agent health update (every poll, best-effort, never blocks)
        self._update_agent_health()

        if self._server and getattr(self._server, "_running", False):
            # Server is alive
            if self._status not in ("connected", "idle", "executing"):
                port = getattr(self._server, "_actual_port", _PORT)
                self._set_status("connected", "port {}".format(port))
            clients = len(getattr(self._server, "_clients", set()))
            if clients:
                self._status_detail.setText(
                    "{} client{}".format(clients, "s" if clients != 1 else "")
                )
        else:
            # Server died unexpectedly
            if self._status in ("connected", "idle", "executing"):
                self._log_activity("Server stopped unexpectedly", "error")
                self._set_status("disconnected")
                self._server = None
                self._health_timer.stop()


# ── Houdini Python Panel Interface ───────────────────────

def onCreateInterface():
    """Called by Houdini to create the panel widget."""
    return SynapsePanel()
]]></script>
  </interface>
</pythonPanelDocument>
