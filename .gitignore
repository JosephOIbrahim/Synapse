# ---------------------------------------------------------------------------
# Vendored dependencies (Sprint 3 Spike 2.2)
# ---------------------------------------------------------------------------
# python/synapse/_vendor/ holds pip-installed anthropic + transitive deps
# (pydantic-core with its .pyd, httpx, httpcore, etc.). The outer rules
# above ignore *.pyd, *.py[cod], *.so, and _*.py — all of which would
# catch vendor contents. Whitelist the whole vendor tree explicitly and
# then re-ignore only the build artefacts we never want committed.
!python/synapse/_vendor/
!python/synapse/_vendor/**
python/synapse/_vendor/**/__pycache__/
python/synapse/_vendor/**/*.pyc

# SCOUT reconnaissance artifacts (read-only investigation output)
.scout/

# FORGE build-orchestration artifacts (run logs, specs)
.forge/

# close-the-loop harness run artifacts
.close-the-loop/

# H22 prep harness — bundle archives + transient check-debug dumps (never tracked)
/H22_prep_harness.zip
/houdini22prepareHarness_v2.zip
.claude/checks_debug_*.txt
harness/notes/_prov_live.json
# API-delta probe run artifacts (regenerated per run; drop-day outputs)
.claude/probe_delta.json
.claude/probe_delta.md
.claude/mcp_surface_delta.json
